tion foo2()\0A    return \2201234567890123456789012345678901234567890123456789\22\0A  end\0A  local a1 = getadd(s1)\0A  assert(a1 == getadd(s2))\0A  assert(a1 == getadd(foo()))\0A  assert(a1 == getadd(foo1()))\0A  assert(a1 == getadd(foo2()))\0A\0A  local sd = \220123456789\22 .. \220123456789012345678901234567890123456789\22\0A  assert(sd == s1 and getadd(sd) ~= a1)\0Aend\0A\0A\0A-- testing line ends\0Aprog = [[\0Alocal a = 1        -- a comment\0Alocal b = 2\0A\0A\0Ax = [=[\0Ahi\0A]=]\0Ay = \22\\\0Ahello\\r\\n\\\0A\22\0Areturn require\22debug\22.getinfo(1).currentline\0A]]\0A\0Afor _, n in pairs{\22\\n\22, \22\\r\22, \22\\n\\r\22, \22\\r\\n\22} do\0A  local prog, nn = string.gsub(prog, \22\\n\22, n)\0A  assert(dostring(prog) == nn)\0A  assert(_G.x == \22hi\\n\22 and _G.y == \22\\nhello\\r\\n\\n\22)\0Aend\0A_G.x, _G.y = nil\0A\0A\0A-- testing comments and strings with long brackets\0Alocal a = [==[]=]==]\0Aassert(a == \22]=\22)\0A\0Aa = [==[[===[[=[]]=][====[]]===]===]==]\0Aassert(a == \22[===[[=[]]=][====[]]===]===\22)\0A\0Aa = [====[[===[[=[]]=][====[]]===]===]====]\0Aassert(a == \22[===[[=[]]=][====[]]===]===\22)\0A\0Aa = [=[]]]]]]]]]=]\0Aassert(a == \22]]]]]]]]\22)\0A\0A\0A--[===[\0Ax y z [==[ blu foo\0A]==\0A]\0A]=]==]\0Aerror error]=]===]\0A\0A-- generate all strings of four of these chars\0Alocal x = {\22=\22, \22[\22, \22]\22, \22\\n\22}\0Alocal len = 4\0Alocal function gen (c, n)\0A  if n==0 then coroutine.yield(c)\0A  else\0A    for _, a in pairs(x) do\0A      gen(c..a, n-1)\0A    end\0A  end\0Aend\0A\0Afor s in coroutine.wrap(function () gen(\22\22, len) end) do\0A  assert(s == load(\22return [====[\\n\22..s..\22]====]\22, \22\22)())\0Aend\0A\0A\0A-- testing decimal point locale\0Aif os.setlocale(\22pt_BR\22) or os.setlocale(\22ptb\22) then\0A  assert(tonumber(\223,4\22) == 3.4 and tonumber\223.4\22 == 3.4)\0A  assert(tonumber(\22  -.4  \22) == -0.4)\0A  assert(tonumber(\22  +0x.41  \22) == 0X0.41)\0A  assert(not load(\22a = (3,4)\22))\0A  assert(assert(load(\22return 3.4\22))() == 3.4)\0A  assert(assert(load(\22return .4,3\22))() == .4)\0A  assert(assert(load(\22return 4.\22))() == 4.)\0A  assert(assert(load(\22return 4.+.5\22))() == 4.5)\0A\0A  assert(\22 0x.1 \22 + \22 0x,1\22 + \22-0X.1\\t\22 == 0x0.1)\0A\0A  assert(not tonumber\22inf\22 and not tonumber\22NAN\22)\0A\0A  assert(assert(load(string.format(\22return %q\22, 4.51)))() == 4.51)\0A\0A  local a,b = load(\22return 4.5.\22)\0A  assert(string.find(b, \22'4%.5%.'\22))\0A\0A  assert(os.setlocale(\22C\22))\0Aelse\0A  (Message or print)(\0A   '\\n >>> pt_BR locale not available: skipping decimal point tests <<<\\n')\0Aend\0A\0A\0A-- testing %q x line ends\0Alocal s = \22a string with \\r and \\n and \\r\\n and \\n\\r\22\0Alocal c = string.format(\22return %q\22, s)\0Aassert(assert(load(c))() == s)\0A\0A-- testing errors\0Aassert(not load\22a = 'non-ending string\22)\0Aassert(not load\22a = 'non-ending string\\n'\22)\0Aassert(not load\22a = '\\\\345'\22)\0Aassert(not load\22a = [=x]\22)\0A\0Alocal function malformednum (n, exp)\0A  local s, msg = load(\22return \22 .. n)\0A  assert(not s and string.find(msg, exp))\0Aend\0A\0Amalformednum(\220xe-\22, \22near <eof>\22)\0Amalformednum(\220xep-p\22, \22malformed number\22)\0Amalformednum(\221print()\22, \22malformed number\22)\0A\0Aprint('OK')\0A", align 16
@t11 = internal constant [19568 x i8] c"-- $Id: testes/errors.lua $\0A-- See Copyright Notice in file all.lua\0A\0Aprint(\22testing errors\22)\0A\0Alocal debug = require\22debug\22\0A\0A-- avoid problems with 'strict' module (which may generate other error messages)\0Alocal mt = getmetatable(_G) or {}\0Alocal oldmm = mt.__index\0Amt.__index = nil\0A\0Alocal function checkerr (msg, f, ...)\0A  local st, err = pcall(f, ...)\0A  assert(not st and string.find(err, msg))\0Aend\0A\0A\0Alocal function doit (s)\0A  local f, msg = load(s)\0A  if not f then return msg end\0A  local cond, msg = pcall(f)\0A  return (not cond) and msg\0Aend\0A\0A\0Alocal function checkmessage (prog, msg, debug)\0A  local m = doit(prog)\0A  if debug then print(m, msg) end\0A  assert(string.find(m, msg, 1, true))\0Aend\0A\0Alocal function checksyntax (prog, extra, token, line)\0A  local msg = doit(prog)\0A  if not string.find(token, \22^<%a\22) and not string.find(token, \22^char%(\22)\0A    then token = \22'\22..token..\22'\22 end\0A  token = string.gsub(token, \22(%p)\22, \22%%%1\22)\0A  local pt = string.format([[^%%[string \22.*\22%%]:%d: .- near %s$]],\0A                           line, token)\0A  assert(string.find(msg, pt))\0A  assert(string.find(msg, msg, 1, true))\0Aend\0A\0A\0A-- test error message with no extra info\0Aassert(doit(\22error('hi', 0)\22) == 'hi')\0A\0A-- test error message with no info\0Aassert(doit(\22error()\22) == nil)\0A\0A\0A-- test common errors/errors that crashed in the past\0Aassert(doit(\22table.unpack({}, 1, n=2^30)\22))\0Aassert(doit(\22a=math.sin()\22))\0Aassert(not doit(\22tostring(1)\22) and doit(\22tostring()\22))\0Aassert(doit\22tonumber()\22)\0Aassert(doit\22repeat until 1; a\22)\0Aassert(doit\22return;;\22)\0Aassert(doit\22assert(false)\22)\0Aassert(doit\22assert(nil)\22)\0Aassert(doit(\22function a (... , ...) end\22))\0Aassert(doit(\22function a (, ...) end\22))\0Aassert(doit(\22local t={}; t = t[#t] + 1\22))\0A\0Achecksyntax([[\0A  local a = {4\0A\0A]], \22'}' expected (to close '{' at line 1)\22, \22<eof>\22, 3)\0A\0A\0Ado   -- testing errors in goto/break\0A  local function checksyntax (prog, msg, line)\0A    local st, err = load(prog)\0A    assert(string.find(err, \22line \22 .. line))\0A    assert(string.find(err, msg, 1, true))\0A  end\0A\0A  checksyntax([[\0A    ::A:: a = 1\0A    ::A::\0A  ]], \22label 'A' already defined\22, 1)\0A\0A  checksyntax([[\0A    a = 1\0A    goto A\0A    do ::A:: end\0A  ]], \22no visible label 'A'\22, 2)\0A\0Aend\0A\0A\0Aif not T then\0A  (Message or print)\0A    ('\\n >>> testC not active: skipping tests for messages in C <<<\\n')\0Aelse\0A  print \22testing memory error message\22\0A  local a = {}\0A  for i = 1, 10000 do a[i] = true end   -- preallocate array\0A  collectgarbage()\0A  T.totalmem(T.totalmem() + 10000)\0A  -- force a memory error (by a small margin)\0A  local st, msg = pcall(function()\0A    for i = 1, 100000 do a[i] = tostring(i) end\0A  end)\0A  T.totalmem(0)\0A  assert(not st and msg == \22not enough\22 .. \22 memory\22)\0A\0A  -- stack space for luaL_traceback (bug in 5.4.6)\0A  local res = T.testC[[\0A    # push 16 elements on the stack\0A    pushnum 1; pushnum 1; pushnum 1; pushnum 1; pushnum 1;\0A    pushnum 1; pushnum 1; pushnum 1; pushnum 1; pushnum 1;\0A    pushnum 1; pushnum 1; pushnum 1; pushnum 1; pushnum 1;\0A    pushnum 1;\0A    # traceback should work with 4 remaining slots\0A    traceback xuxu 1;\0A    return 1\0A  ]]\0A  assert(string.find(res, \22xuxu.-main chunk\22))\0Aend\0A\0A\0A-- tests for better error messages\0A\0Acheckmessage(\22a = {} + 1\22, \22arithmetic\22)\0Acheckmessage(\22a = {} | 1\22, \22bitwise operation\22)\0Acheckmessage(\22a = {} < 1\22, \22attempt to compare\22)\0Acheckmessage(\22a = {} <= 1\22, \22attempt to compare\22)\0A\0Acheckmessage(\22aaa=1; bbbb=2; aaa=math.sin(3)+bbbb(3)\22, \22global 'bbbb'\22)\0Acheckmessage(\22aaa={}; do local aaa=1 end aaa:bbbb(3)\22, \22method 'bbbb'\22)\0Acheckmessage(\22local a={}; a.bbbb(3)\22, \22field 'bbbb'\22)\0Aassert(not string.find(doit\22aaa={13}; local bbbb=1; aaa[bbbb](3)\22, \22'bbbb'\22))\0Acheckmessage(\22aaa={13}; local bbbb=1; aaa[bbbb](3)\22, \22number\22)\0Acheckmessage(\22aaa=(1)..{}\22, \22a table value\22)\0A\0A-- bug in 5.4.6\0Acheckmessage(\22a = {_ENV = {}}; print(a._ENV.x + 1)\22, \22field 'x'\22)\0A\0A_G.aaa, _G.bbbb = nil\0A\0A-- calls\0Acheckmessage(\22local a; a(13)\22, \22local 'a'\22)\0Acheckmessage([[\0A  local a = setmetatable({}, {__add = 34})\0A  a = a + 1\0A]], \22metamethod 'add'\22)\0Acheckmessage([[\0A  local a = setmetatable({}, {__lt = {}})\0A  a = a > a\0A]], \22metamethod 'lt'\22)\0A\0A-- tail calls\0Acheckmessage(\22local a={}; return a.bbbb(3)\22, \22field 'bbbb'\22)\0Acheckmessage(\22aaa={}; do local aaa=1 end; return aaa:bbbb(3)\22, \22method 'bbbb'\22)\0A\0Acheckmessage(\22aaa = #print\22, \22length of a function value\22)\0Acheckmessage(\22aaa = #3\22, \22length of a number value\22)\0A\0A_G.aaa = nil\0A\0Acheckmessage(\22aaa.bbb:ddd(9)\22, \22global 'aaa'\22)\0Acheckmessage(\22local aaa={bbb=1}; aaa.bbb:ddd(9)\22, \22field 'bbb'\22)\0Acheckmessage(\22local aaa={bbb={}}; aaa.bbb:ddd(9)\22, \22method 'ddd'\22)\0Acheckmessage(\22local a,b,c; (function () a = b+1.1 end)()\22, \22upvalue 'b'\22)\0Aassert(not doit\22local aaa={bbb={ddd=next}}; aaa.bbb:ddd(nil)\22)\0A\0A-- upvalues being indexed do not go to the stack\0Acheckmessage(\22local a,b,cc; (function () a = cc[1] end)()\22, \22upvalue 'cc'\22)\0Acheckmessage(\22local a,b,cc; (function () a.x = 1 end)()\22, \22upvalue 'a'\22)\0A\0Acheckmessage(\22local _ENV = {x={}}; a = a + 1\22, \22global 'a'\22)\0A\0Acheckmessage(\22BB=1; local aaa={}; x=aaa+BB\22, \22local 'aaa'\22)\0Acheckmessage(\22aaa={}; x=3.3/aaa\22, \22global 'aaa'\22)\0Acheckmessage(\22aaa=2; BB=nil;x=aaa*BB\22, \22global 'BB'\22)\0Acheckmessage(\22aaa={}; x=-aaa\22, \22global 'aaa'\22)\0A\0A-- short circuit\0Acheckmessage(\22aaa=1; local aaa,bbbb=2,3; aaa = math.sin(1) and bbbb(3)\22,\0A  