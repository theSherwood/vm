ing.len(prog), step do\0A      pcall(load(string.sub(prog, i, j), \22\22))\0A    end\0A  end\0Aend\0Arawset(_G, \22a\22, nil)\0A_G.x = nil\0A\0Ado\0A  foo = nil\0A  print('long strings')\0A  local x = \2201234567890123456789012345678901234567890123456789012345678901234567890123456789\22\0A  assert(string.len(x)==80)\0A  local s = ''\0A  local k = math.min(300, (math.maxinteger // 80) // 2)\0A  for n = 1, k do s = s..x; local j=tostring(n)  end\0A  assert(string.len(s) == k*80)\0A  s = string.sub(s, 1, 10000)\0A  local s, i = string.gsub(s, '(%d%d%d%d)', '')\0A  assert(i==10000 // 4)\0A\0A  assert(_G[\22while\22] == 234)\0A  _G[\22while\22] = nil\0Aend\0A\0A\0A--\0A-- test the \22size\22 of basic GC steps (whatever they mean...)\0A--\0Ado\0Aprint(\22steps\22)\0A\0A  print(\22steps (2)\22)\0A\0A  local function dosteps (siz)\0A    collectgarbage()\0A    local a = {}\0A    for i=1,100 do a[i] = {{}}; local b = {} end\0A    local x = gcinfo()\0A    local i = 0\0A    repeat   -- do steps until it completes a collection cycle\0A      i = i+1\0A    until collectgarbage(\22step\22, siz)\0A    assert(gcinfo() < x)\0A    return i    -- number of steps\0A  end\0A\0A  collectgarbage\22stop\22\0A\0A  if not _port then\0A    assert(dosteps(10) < dosteps(2))\0A  end\0A\0A  -- collector should do a full collection with so many steps\0A  assert(dosteps(20000) == 1)\0A  assert(collectgarbage(\22step\22, 20000) == true)\0A  assert(collectgarbage(\22step\22, 20000) == true)\0A\0A  assert(not collectgarbage(\22isrunning\22))\0A  collectgarbage\22restart\22\0A  assert(collectgarbage(\22isrunning\22))\0A\0Aend\0A\0A\0Aif not _port then\0A  -- test the pace of the collector\0A  collectgarbage(); collectgarbage()\0A  local x = gcinfo()\0A  collectgarbage\22stop\22\0A  repeat\0A    local a = {}\0A  until gcinfo() > 3 * x\0A  collectgarbage\22restart\22\0A  assert(collectgarbage(\22isrunning\22))\0A  repeat\0A    local a = {}\0A  until gcinfo() <= x * 2\0Aend\0A\0A\0Aprint(\22clearing tables\22)\0Alocal lim = 15\0Alocal a = {}\0A-- fill a with `collectable' indices\0Afor i=1,lim do a[{}] = i end\0Ab = {}\0Afor k,v in pairs(a) do b[k]=v end\0A-- remove all indices and collect them\0Afor n in pairs(b) do\0A  a[n] = undef\0A  assert(type(n) == 'table' and next(n) == nil)\0A  collectgarbage()\0Aend\0Ab = nil\0Acollectgarbage()\0Afor n in pairs(a) do error'cannot be here' end\0Afor i=1,lim do a[i] = i end\0Afor i=1,lim do assert(a[i] == i) end\0A\0A\0Aprint('weak tables')\0Aa = {}; setmetatable(a, {__mode = 'k'});\0A-- fill a with some `collectable' indices\0Afor i=1,lim do a[{}] = i end\0A-- and some non-collectable ones\0Afor i=1,lim do a[i] = i end\0Afor i=1,lim do local s=string.rep('@', i); a[s] = s..'#' end\0Acollectgarbage()\0Alocal i = 0\0Afor k,v in pairs(a) do assert(k==v or k..'#'==v); i=i+1 end\0Aassert(i == 2*lim)\0A\0Aa = {}; setmetatable(a, {__mode = 'v'});\0Aa[1] = string.rep('b', 21)\0Acollectgarbage()\0Aassert(a[1])   -- strings are *values*\0Aa[1] = undef\0A-- fill a with some `collectable' values (in both parts of the table)\0Afor i=1,lim do a[i] = {} end\0Afor i=1,lim do a[i..'x'] = {} end\0A-- and some non-collectable ones\0Afor i=1,lim do local t={}; a[t]=t end\0Afor i=1,lim do a[i+lim]=i..'x' end\0Acollectgarbage()\0Alocal i = 0\0Afor k,v in pairs(a) do assert(k==v or k-lim..'x' == v); i=i+1 end\0Aassert(i == 2*lim)\0A\0Aa = {}; setmetatable(a, {__mode = 'kv'});\0Alocal x, y, z = {}, {}, {}\0A-- keep only some items\0Aa[1], a[2], a[3] = x, y, z\0Aa[string.rep('$', 11)] = string.rep('$', 11)\0A-- fill a with some `collectable' values\0Afor i=4,lim do a[i] = {} end\0Afor i=1,lim do a[{}] = i end\0Afor i=1,lim do local t={}; a[t]=t end\0Acollectgarbage()\0Aassert(next(a) ~= nil)\0Alocal i = 0\0Afor k,v in pairs(a) do\0A  assert((k == 1 and v == x) or\0A         (k == 2 and v == y) or\0A         (k == 3 and v == z) or k==v);\0A  i = i+1\0Aend\0Aassert(i == 4)\0Ax,y,z=nil\0Acollectgarbage()\0Aassert(next(a) == string.rep('$', 11))\0A\0A\0A