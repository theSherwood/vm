@t20 = internal constant [12024 x i8] c"-- $Id: testes/calls.lua $\0A-- See Copyright Notice in file all.lua\0A\0Aprint(\22testing functions and calls\22)\0A\0Alocal debug = require \22debug\22\0A\0A-- get the opportunity to test 'type' too ;)\0A\0Aassert(type(1<2) == 'boolean')\0Aassert(type(true) == 'boolean' and type(false) == 'boolean')\0Aassert(type(nil) == 'nil'\0A   and type(-3) == 'number'\0A   and type'x' == 'string'\0A   and type{} == 'table'\0A   and type(type) == 'function')\0A\0Aassert(type(assert) == type(print))\0Alocal function f (x) return a:x (x) end\0Aassert(type(f) == 'function')\0Aassert(not pcall(type))\0A\0A\0A-- testing local-function recursion\0Afact = false\0Ado\0A  local res = 1\0A  local function fact (n)\0A    if n==0 then return res\0A    else return n*fact(n-1)\0A    end\0A  end\0A  assert(fact(5) == 120)\0Aend\0Aassert(fact == false)\0Afact = nil\0A\0A-- testing declarations\0Alocal a = {i = 10}\0Alocal self = 20\0Afunction a:x (x) return x+self.i end\0Afunction a.y (x) return x+self end\0A\0Aassert(a:x(1)+10 == a.y(1))\0A\0Aa.t = {i=-100}\0Aa[\22t\22].x = function (self, a,b) return self.i+a+b end\0A\0Aassert(a.t:x(2,3) == -95)\0A\0Ado\0A  local a = {x=0}\0A  function a:add (x) self.x, a.y = self.x+x, 20; return self end\0A  assert(a:add(10):add(20):add(30).x == 60 and a.y == 20)\0Aend\0A\0Alocal a = {b={c={}}}\0A\0Afunction a.b.c.f1 (x) return x+1 end\0Afunction a.b.c:f2 (x,y) self[x] = y end\0Aassert(a.b.c.f1(4) == 5)\0Aa.b.c:f2('k', 12); assert(a.b.c.k == 12)\0A\0Aprint('+')\0A\0At = nil   -- 'declare' t\0Afunction f(a,b,c) local d = 'a'; t={a,b,c,d} end\0A\0Af(      -- this line change must be valid\0A  1,2)\0Aassert(t[1] == 1 and t[2] == 2 and t[3] == nil and t[4] == 'a')\0Af(1,2,   -- this one too\0A      3,4)\0Aassert(t[1] == 1 and t[2] == 2 and t[3] == 3 and t[4] == 'a')\0A\0At = nil   -- delete 't'\0A\0Afunction fat(x)\0A  if x <= 1 then return 1\0A  else return x*load(\22return fat(\22 .. x-1 .. \22)\22, \22\22)()\0A  end\0Aend\0A\0Aassert(load \22load 'assert(fat(6)==720)' () \22)()\0Aa = load('return fat(5), 3')\0Alocal a,b = a()\0Aassert(a == 120 and b == 3)\0Afat = nil\0Aprint('+')\0A\0Alocal function err_on_n (n)\0A  if n==0 then error(); exit(1);\0A  else err_on_n (n-1); exit(1);\0A  end\0Aend\0A\0Ado\0A  local function dummy (n)\0A    if n > 0 then\0A      assert(not pcall(err_on_n, n))\0A      dummy(n-1)\0A    end\0A  end\0A\0A  dummy(10)\0Aend\0A\0A_G.deep = nil   -- \22declaration\22  (used by 'all.lua')\0A\0Afunction deep (n)\0A  if n>0 then deep(n-1) end\0Aend\0Adeep(10)\0Adeep(180)\0A\0A\0Aprint\22testing tail calls\22\0A\0Afunction deep (n) if n>0 then return deep(n-1) else return 101 end end\0Aassert(deep(30000) == 101)\0Aa = {}\0Afunction a:deep (n) if n>0 then return self:deep(n-1) else return 101 end end\0Aassert(a:deep(30000) == 101)\0A\0Ado   -- tail calls x varargs\0A  local function foo (x, ...) local a = {...}; return x, a[1], a[2] end\0A\0A  local function foo1 (x) return foo(10, x, x + 1) end\0A\0A  local a, b, c = foo1(-2)\0A  assert(a == 10 and b == -2 and c == -1)\0A\0A  -- tail calls x metamethods\0A  local t = setmetatable({}, {__call = foo})\0A  local function foo2 (x) return t(10, x) end\0A  a, b, c = foo2(100)\0A  assert(a == t and b == 10 and c == 100)\0A\0A  a, b = (function () return foo() end)()\0A  assert(a == nil and b == nil)\0A\0A  local X, Y, A\0A  local function foo (x, y, ...) X = x; Y = y; A = {...} end\0A  local function foo1 (...) return foo(...) end\0A\0A  local a, b, c = foo1()\0A  assert(X == nil and Y == nil and #A == 0)\0A\0A  a, b, c = foo1(10)\0A  assert(X == 10 and Y == nil and #A == 0)\0A\0A  a, b, c = foo1(10, 20)\0A  assert(X == 10 and Y == 20 and #A == 0)\0A\0A  a, b, c = foo1(10, 20, 30)\0A  assert(X == 10 and Y == 20 and #A == 1 and A[1] == 30)\0Aend\0A\0A\0Ado   -- C-stack overflow while handling C-stack overflow\0A  local function loop ()\0A    assert(pcall(loop))\0A  end\0A\0A  local err, msg = xpcall(loop, loop)\0A  assert(not err and string.find(msg, \22error\22))\0Aend\0A\0A\0A\0Ado   -- tail calls x chain of __call\0A  local n = 10000   -- depth\0A\0A  local function foo ()\0A    if n == 0 then return 1023\0A    else n = n - 1; return foo()\0A    end\0A  end\0A\0A  -- build a chain of __call metamethods ending in function 'foo'\0A  for i = 1, 100 do\0A    foo = setmetatable({}, {__call = foo})\0A  end\0A\0A  -- call the first one as a tail call in a new coroutine\0A  -- (to ensure stack is not preallocated)\0A  assert(coroutine.wrap(function() return foo() end)() == 1023)\0Aend\0A\0Aprint('+')\0A\0A\0Ado  -- testing chains of '__call'\0A  local N = 20\0A  local u = table.pack\0A  for i = 1, N do\0A    u = setmetatable({i}, {__call = u})\0A  end\0A\0A  local Res = u(\22a\22, \22b\22, \22c\22)\0A\0A  assert(Res.n == N + 3)\0A  for i = 1, N do\0A    assert(Res[i][1] == i)\0A  end\0A  assert(Res[N + 1] == \22a\22 and Res[N + 2] == \22b\22 and Res[N + 3] == \22c\22)\0Aend\0A\0A\0Aa = nil\0A(function (x) a=x end)(23)\0Aassert(a == 23 and (function (x) return x*2 end)(20) == 40)\0A\0A\0A-- testing closures\0A\0A-- fixed-point operator\0Alocal Z = function (le)\0A      local function a (f)\0A        return le(function (x) return f(f)(x) end)\0A      end\0A      return a(a)\0A    end\0A\0A\0A-- non-recursive factorial\0A\0Alocal F = function (f)\0A      return function (n)\0A               if n == 0 then return 1\0A               else return n*f(n-1) end\0A             end\0A    end\0A\0Alocal fat = Z(F)\0A\0Aassert(fat(0) == 1 and fat(4) == 24 and Z(F)(5)==5*Z(F)(4))\0A\0Alocal function g (z)\0A  local function f (a,b,c,d)\0A    return function (x,y) return a+b+c+d+a+x+y+z end\0A  end\0A  return f(z,z+1,z+2,z+3)\0Aend\0A\0Alocal f = g(10)\0Aassert(f(9, 16) == 10+11+12+13+10+9+16+10)\0A\0Aprint('+')\0A\0A-- testing multiple returns\0A\0Alocal function unlpack (t, i)\0A  i = i or 1\0A  if (i <= #t) then\0A    return t[i], unlpack(t, i+1)\0A  end\0Aend\0A\0Alocal function equaltab (t1, t2)\0A  assert(#t1 == #t2)\0A  for i = 1, #t1 do\0A    assert(t1[i] == t2[i])\0A  end\0Aend\0A\0Alocal pack = function (...) return (table.pack(...)) end\0A\0Alocal function f() return 1,2,30,4 end\0Alocal function ret2 (a,b) return a,b end\0A\0Alocal a,b,c,d = unlpack{1,2,3}\0Aassert(a==1 and b==2 and c==3 and d==nil)\0Aa = {1,2,3,4,false,10,'alo',false,assert}\0Aequaltab(pack(unlpack(a)), a)\0Aequaltab(pack(unlpack(a), -1), {1,-1})\0Aa,b,c,d = ret2(f()), ret2(f())\0Aassert(a==1 and b==1 and c==2 and d==nil)\0Aa,b,c,d = unlpack(pack(ret2(f()), ret2(f())))\0Aassert(a==1 and b==1 and c==2 and d==nil)\0Aa,b,c,d = unlpack(pack(ret2(f()), (ret2(f()))))\0Aassert(a==1 and b==1 and c==nil and d==nil)\0A\0Aa = ret2{ unlpack{1,2,3}, unlpack{3,2,1}, unlpack{\22a\22, \22b\22}}\0Aassert(a[1] == 1 and a[2] == 3 and a[3] == \22a\22 and a[4] == \22b\22)\0A\0A\0A-- testing calls with 'incorrect' arguments\0Arawget({}, \22x\22, 1)\0Arawset({}, \22x\22, 1, 2)\0Aassert(math.sin(1,2) == math.sin(1))\0Atable.sort({10,9,8,4,19,23,0,0}, function (a,b) return a<b end, \22extra arg\22)\0A\0A\0A-- test for generic load\0Alocal x = \22-- a comment\\0\\0\\0\\n  x = 10 + \\n23; \\\0A     local a = function () x = 'hi' end; \\\0A     return '\\0'\22\0Alocal function read1 (x)\0A  local i = 0\0A  return function ()\0A    collectgarbage()\0A    i=i+1\0A    return string.sub(x, i, i)\0A  end\0Aend\0A\0Alocal function cannotload (msg, a,b)\0A  assert(not a and string.find(b, msg))\0Aend\0A\0Aa = assert(load(read1(x), \22modname\22, \22t\22, _G))\0Aassert(a() == \22\\0\22 and _G.x == 33)\0Aassert(debug.getinfo(a).source == \22modname\22)\0A-- cannot read text in binary mode\0Acannotload(\22attempt to load a text chunk\22, load(read1(x), \22modname\22, \22b\22, {}))\0Acannotload(\22attempt to load a text chunk\22, load(x, \22modname\22, \22b\22))\0A\0Aa = assert(load(function () return nil end))\0Aa()  -- empty chunk\0A\0Aassert(not load(function () return true end))\0A\0A\0A-- small bug\0Alocal t = {nil