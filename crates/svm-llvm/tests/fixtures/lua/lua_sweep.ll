 nil)\0A  return x\0Aend)\0Aa, b = coroutine.resume(co, 10)\0Aassert(a and b == 10)\0Aa, b = debug.getlocal(co, 1, 1)\0Aassert(a == \22x\22 and b == 10)\0Aassert(not debug.getlocal(co, 1, 5))\0Aassert(debug.setlocal(co, 1, 1, 30) == \22x\22)\0Aassert(not debug.setlocal(co, 1, 5, 40))\0Aa, b = coroutine.resume(co, 100)\0Aassert(a and b == 30)\0A\0A\0A-- check traceback of suspended (or dead with error) coroutines\0A\0Afunction f(i)\0A  if i == 0 then error(i)\0A  else coroutine.yield(); f(i-1)\0A  end\0Aend\0A\0A\0Aco = coroutine.create(function (x) f(x) end)\0Aa, b = coroutine.resume(co, 3)\0At = {\22'coroutine.yield'\22, \22'f'\22, \22in function <\22}\0Awhile coroutine.status(co) == \22suspended\22 do\0A  checktraceback(co, t)\0A  a, b = coroutine.resume(co)\0A  table.insert(t, 2, \22'f'\22)   -- one more recursive call to 'f'\0Aend\0At[1] = \22'error'\22\0Achecktraceback(co, t)\0A\0A\0A-- test acessing line numbers of a coroutine from a resume inside\0A-- a C function (this is a known bug in Lua 5.0)\0A\0Alocal function g(x)\0A    coroutine.yield(x)\0Aend\0A\0Alocal function f (i)\0A  debug.sethook(function () end, \22l\22)\0A  for j=1,1000 do\0A    g(i+j)\0A  end\0Aend\0A\0Alocal co = coroutine.wrap(f)\0Aco(10)\0Apcall(co)\0Apcall(co)\0A\0A\0Aassert(type(debug.getregistry()) == \22table\22)\0A\0A\0A-- test tagmethod information\0Alocal a = {}\0Alocal function f (t)\0A  local info = debug.getinfo(1);\0A  assert(info.namewhat == \22metamethod\22)\0A  a.op = info.name\0A  return info.name\0Aend\0Asetmetatable(a, {\0A  __index = f; __add = f; __div = f; __mod = f; __concat = f; __pow = f;\0A  __mul = f; __idiv = f; __unm = f; __len = f; __sub = f;\0A  __shl = f; __shr = f; __bor = f; __bxor = f;\0A  __eq = f; __le = f; __lt = f; __unm = f; __len = f; __band = f;\0A  __bnot = f;\0A})\0A\0Alocal b = setmetatable({}, getmetatable(a))\0A\0Aassert(a[3] == \22index\22 and a^3 == \22pow\22 and a..a == \22concat\22)\0Aassert(a/3 == \22div\22 and 3%a == \22mod\22)\0Aassert(a+3 == \22add\22 and 3-a == \22sub\22 and a*3 == \22mul\22 and\0A       -a == \22unm\22 and #a == \22len\22 and a&3 == \22band\22)\0Aassert(a + 30000 == \22add\22 and a - 3.0 == \22sub\22 and a * 3.0 == \22mul\22 and\0A       -a == \22unm\22 and #a == \22len\22 and a & 3 == \22band\22)\0Aassert(a|3 == \22bor\22 and 3~a == \22bxor\22 and a<<3 == \22shl\22 and a>>1 == \22shr\22)\0Aassert (a==b and a.op == \22eq\22)\0Aassert (a>=b and a.op == \22le\22)\0Aassert (\22x\22>=a and a.op == \22le\22)\0Aassert (a>b and a.op == \22lt\22)\0Aassert (a>10 and a.op == \22lt\22)\0Aassert(~a == \22bnot\22)\0A\0Ado   -- testing for-iterator name\0A  local function f()\0A    assert(debug.getinfo(1).name == \22for iterator\22)\0A  end\0A\0A  for i in f do end\0Aend\0A\0A\0Ado   -- testing debug info for finalizers\0A  local name = nil\0A\0A  -- create a piece of garbage with a finalizer\0A  setmetatable({}, {__gc = function ()\0A    local t = debug.getinfo(1)   -- get function information\0A    assert(t.namewhat == \22metamethod\22)\0A    name = t.name\0A  end})\0A\0A  -- repeat until previous finalizer runs (setting 'name')\0A  repeat local a = {} until name\0A  assert(name == \22__gc\22)\0Aend\0A\0A\0Ado\0A  print(\22testing traceback sizes\22)\0A\0A  local function countlines (s)\0A    return select(2, string.gsub(s, \22\\n\22, \22\22))\0A  end\0A\0A  local function deep (lvl, n)\0A    if lvl == 0 then\0A      return (debug.traceback(\22message\22, n))\0A    else\0A      return (deep(lvl-1, n))\0A    end\0A  end\0A\0A  local function checkdeep (total, start)\0A    local s = deep(total, start)\0A    local rest = string.match(s, \22^message\\nstack traceback:\\n(.*)$\22)\0A    local cl = countlines(rest)\0A    -- at most 10 lines in first part, 11 in second, plus '...'\0A    assert(cl <= 10 + 11 + 1)\0A    local brk = string.find(rest, \22%.%.%.\\t%(skip\22)\0A    if brk then   -- does message have '...'?\0A      local rest1 = string.sub(rest, 1, brk)\0A      local rest2 = string.sub(rest, brk, #rest)\0A      assert(countlines(rest1) == 10 and countlines(rest2) == 11)\0A    else\0A      assert(cl == total - start + 2)\0A    end\0A  end\0A\0A  for d = 1, 51, 10 do\0A    for l = 1, d do\0A      -- use coroutines to ensure complete control of the stack\0A      coroutine.wrap(checkdeep)(d, l)\0A    end\0A  end\0A\0Aend\0A\0A\0Aprint(\22testing debug functions on chunk without debug info\22)\0Alocal prog = [[-- program to be loaded without debug information (strip)\0Alocal debug = require'debug'\0Alocal a = 12  -- a local variable\0A\0Alocal n, v = debug.getlocal(1, 1)\0Aassert(n == \22(temporary)\22 and v == debug)   -- unkown name but known value\0An, v = debug.getlocal(1, 2)\0Aassert(n == \22(temporary)\22 and v == 12)   -- unkown name but known value\0A\0A-- a function with an upvalue\0Alocal f = function () local x; return a end\0An, v = debug.getupvalue(f, 1)\0Aassert(n == \22(no name)\22 and v == 12)\0Aassert(debug.setupvalue(f, 1, 13) == \22(no name)\22)\0Aassert(a == 13)\0A\0Alocal t = debug.getinfo(f)\0Aassert(t.name == nil and t.linedefined > 0 and\0A       t.lastlinedefined == t.linedefined and\0A       t.short_src == \22?\22)\0Aassert(debug.getinfo(1).currentline == -1)\0A\0At = debug.getinfo(f, \22L\22).activelines\0Aassert(next(t) == nil)    -- active lines are empty\0A\0A-- dump/load a function without debug info\0Af = load(string.dump(f))\0A\0At = debug.getinfo(f)\0Aassert(t.name == nil and t.linedefined > 0 and\0A       t.lastlinedefined == t.linedefined and\0A       t.short_src == \22?\22)\0Aassert(debug.getinfo(1).currentline == -1)\0A\0Areturn a\0A]]\0A\0A\0A-- load 'prog' without debug info\0Alocal f = assert(load(string.dump(load(prog), true)))\0A\0Aassert(f() == 13)\0A\0Ado   -- bug in 5.4.0: line hooks in stripped code\0A  local function foo ()\0A    local a = 1\0A    local b = 2\0A    return b\0A  end\0A\0A  local s = load(string.dump(foo, true))\0A  local line = true\0A  debug.sethook(function (e, l)\0A    assert(e == \22line\22)\0A    line = l\0A  end, \22l\22)\0A  assert(s() == 2); debug.sethook(nil)\0A  assert(line == nil)  -- hook called withoug debug info for 1st instruction\0Aend\0A\0Ado   -- tests for 'source' in binary dumps\0A  local prog = [[\0A    return function (x)\0A      return function (y) \0A        return x + y\0A      end\0A    end\0A  ]]\0A  local name = string.rep(\22x\22, 1000)\0A  local p = assert(load(prog, name))\0A  -- load 'p' as a binary chunk with debug information\0A  local c = string.dump(p)\0A  assert(#c > 1000 and #c < 2000)   -- no repetition of 'source' in dump\0A  local f = assert(load(c))\0A  local g = f()\0A  local h = g(3)\0A  assert(h(5) == 8)\0A  assert(debug.getinfo(f).source == name and   -- all functions have 'source'\0A         debug.getinfo(g).source == name and \0A         debug.getinfo(h).source == name)\0A  -- again, without debug info\0A  local c = string.dump(p, true)\0A  assert(#c < 500)   -- no 'source' in dump\0A  local f = assert(load(c))\0A  local g = f()\0A  local h = g(30)\0A  assert(h(50) == 80)\0A  assert(debug.getinfo(f).source == '=?' and   -- no function has 'source'\0A         debug.getinfo(g).source == '=?' and \0A         debug.getinfo(h).source == '=?')\0Aend\0A\0Aprint\22OK\22\0A\0A", align 16
@t15 = internal constant [9946 x i8] c"-- $Id: testes/constructs.lua $\0A-- See Copyright Notice in file all.lua\0A\0A;;print \22testing syntax\22;;\0A\0Alocal debug = require \22debug\22\0A\0A\0Alocal function checkload (s, msg)\0A  assert(string.find(select(2, load(s)), msg))\0Aend\0A\0A-- testing semicollons\0Alocal a\0Ado ;;; end\0A; do ; a = 3; assert(a == 3) end;\0A;\0A\0A\0A-- invalid operations should not raise errors when not executed\0Aif false then a = 3 // 0; a = 0 % 0 end\0A\0A\0A-- testing priorities\0A\0Aassert(2^3^2 == 2^(3^2));\0Aassert(2^3*4 == (2^3)*4);\0Aassert(2.0^-2 == 1/4 and -2^- -2 == - - -4);\0Aassert(not nil and 2 and not(2>3 or 3<2));\0Aassert(-3-1-5 == 0+0-9);\0Aassert(-2^2 == -4 and (-2)^2 == 4 and 2*2-3-1 == 0);\0Aassert(-3%5 == 2 and -3+5 == 2)\0Aassert(2*1+3/3 == 3 and 1+2 .. 3*1 == \2233\22);\0Aassert(not(2+1 > 3*1) and \22a\22..\22b\22 > \22a\22);\0A\0Aassert(0xF0 | 0xCC ~ 0xAA & 0xFD == 0xF4)\0Aassert(0xFD & 0xAA ~ 0xCC | 0xF0 == 0xF4)\0Aassert(0xF0 & 0x0F + 1 == 0x10)\0A\0Aassert(3^4//2^3//5 == 2)\0A\0Aassert(-3+4*5//2^3^2//9+4%10/3 == (-3)+(((4*5)//(2^(3^2)))//9)+((4%10)/3))\0A\0Aassert(not ((true or false) and nil))\0Aassert(      true or false  and nil)\0A\0A-- old bug\0Aassert((((1 or false) and true) or false) == true)\0Aassert((((nil and true) or false) and true) == false)\0A\0Alocal a,b = 1,nil;\0Aassert(-(1 or 2) == -1 and (1 and 2)+(-1.25 or -4) == 0.75);\0Alocal x = ((b or a)+1 == 2 and (10 or a)+1 == 11); assert(x);\0Ax = (((2<3) or 1) == true and (2<3 and 4) == 4); assert(x);\0A\0Alocal x, y = 1, 2;\0Aassert((x>y) and x or y == 2);\0Ax,y=2,1;\0Aassert((x>y) and x or y == 2);\0A\0Aassert(1234567890 == tonumber('1234567890') and 1234567890+1 == 1234567891)\0A\0Ado   -- testing operators with diffent kinds of constants\0A  -- operands to consider:\0A  --  * fit in register\0A  --  * constant doesn't fit in register\0A  --  * floats with integral values\0A  local operand = {3, 100, 5.0, -10, -5.0, 10000, -10000}\0A  local operator = {\22+\22, \22-\22, \22*\22, \22/\22, \22//\22, \22%\22, \22^\22,\0A                    \22&\22, \22|\22, \22^\22, \22<<\22, \22>>\22,\0A                    \22==\22, \22~=\22, \22<\22, \22>\22, \22<=\22, \22>=\22,}\0A  for _, op in ipairs(operator) do\0A    local f = assert(load(string.format([[return function (x,y)\0A                return x %s y\0A              end]], op)))();\0A    for _, o1 in ipairs(operand) do\0A      for _, o2 in ipairs(operand) do\0A        local gab = f(o1, o2)\0A\0A        _ENV.XX = o1\0A        local code = string.format(\22return XX %s %s\22, op, o2)\0A        local res = assert(load(code))()\0A        assert(res == gab)\0A\0A        _ENV.XX = o2\0A        code = string.format(\22return (%s) %s XX\22, o1, op)\0A        res = assert(load(code))()\0A        assert(res == gab)\0A\0A        code = string.format(\22return (%s) %s %s\22, o1, op, o2)\0A        res = assert(load(code))()\0A        assert(res == gab)\0A      end\0A    end\0A  end\0A  _ENV.XX = nil\0Aend\0A\0A\0A-- silly loops\0Arepeat until 1; repeat until true;\0Awhile false do end; while nil do end;\0A\0Ado  -- test old bug (first name could not be an `upvalue')\0A local a; local function f(x) x={a=1}; x={x=1}; x={G=1} end\0Aend\0A\0A\0Ado   -- bug since 5.4.0\0A  -- create code with a table using more than 256 constants\0A  local code = {\22local x = {\22}\0A  for i = 1, 257 do\0A    code[#code + 1] = i .. \22.1,\22\0A  end\0A  code[#code + 1] = \22};\22\0A  code = table.concat(code)\0A\0A  -- add \22ret\22 to the end of that code and checks that\0A  -- it produces the expected value \22val\22\0A  local function check (ret, val)\0A    local code = code .. ret\0A    code = load(code)\0A    assert(code() == val)\0A  end\0A\0A  check(\22return (1 ~ (2 or 3))\22, 1 ~ 2)\0A  check(\22return (1 | (2 or 3))\22, 1 | 2)\0A  check(\22return (1 + (2 or 3))\22, 1 + 2)\0A  check(\22return (1 << (2 or 3))\22, 1 << 2)\0Aend\0A\0A\0Alocal function f (i)\0A  if type(i) ~= 'number' then return i,'jojo'; end;\0A  if i > 0 then return i, f(i-1); end;\0Aend\0A\0Ax = {f(3), f(5), f(10);};\0Aassert(x[1] == 3 and x[2] == 5 and x[3] == 10 and x[4] == 9 and x[12] == 1);\0Aassert(x[nil] == nil)\0Ax = {f'alo', f'xixi', nil};\0Aassert(x[1] == 'alo' and x[2] == 'xixi' and x[3] == nil);\0Ax = {f'alo'..'xixi'};\0Aassert(x[1] == 'aloxixi')\0Ax = {f{}}\0Aassert(x[2] == 'jojo' and type(x[1]) == 'table')\0A\0A\0Alocal f = function (i)\0A  if i < 10 then return 'a';\0A  elseif i < 20 then return 'b';\0A  elseif i < 30 then return 'c';\0A  end;\0Aend\0A\0Aassert(f(3) == 'a' and f(12) == 'b' and f(26) == 'c' and f(100) == nil)\0A\0Afor i=1,1000 do break; end;\0Alocal n=100;\0Alocal i=3;\0Alocal t = {};\0Alocal a=nil\0Awhile not a do\0A  a=0; for i=1,n do for i=i,1,-1 do a=a+1; t[i]=1; end; end;\0Aend\0Aassert(a == n*(n+1)/2 and i==3);\0Aassert(t[1] and t[n] and not t[0] and not t[n+1])\0A\0Afunction f(b)\0A  local x = 1;\0A  repeat\0A    local a;\0A    if b==1 then local b=1; x=10; break\0A    elseif b==2 then x=20; break;\0A    elseif b==3 then x=30;\0A    else local a,b,c,d=math.sin(1); x=x+1;\0A    end\0A  until x>=12;\0A  return x;\0Aend;\0A\0Aassert(f(1) == 10 and f(2) == 20 and f(3) == 30 and f(4)==12)\0A\0A\0Alocal f = function (i)\0A  if i < 10 then return 'a'\0A  elseif i < 20 then return 'b'\0A  elseif i < 30 then return 'c'\0A  else return 8\0A  end\0Aend\0A\0Aassert(f(3) == 'a' and f(12) == 'b' and f(26) == 'c' and f(100) == 8)\0A\0Alocal a, b = nil, 23\0Ax = {f(100)*2+3 or a, a or b+2}\0Aassert(x[1] == 19 and x[2] == 25)\0Ax = {f=2+3 or a, a = b+2}\0Aassert(x.f == 5 and x.a == 25)\0A\0Aa={y=1}\0Ax = {a.y}\0Aassert(x[1] == 1)\0A\0Alocal function f (i)\0A  while 1 do\0A    if i>0 then i=i-1;\0A    else return; end;\0A  end;\0Aend;\0A\0Alocal function g(i)\0A  while 1 do\0A    if i>0 then i=i-1\0A    else return end\0A  end\0Aend\0A\0Af(10); g(10);\0A\0Ado\0A  function f () return 1,2,3; end\0A  local a, b, c = f();\0A  assert(a==1 and b==2 and c==3)\0A  a, b, c = (f());\0A  assert(a==1 and b==nil and c==nil)\0Aend\0A\0Alocal a,b = 3 and f();\0Aassert(a==1 and b==nil)\0A\0Afunction g() f(); return; end;\0Aassert(g() == nil)\0Afunction g() return nil or f() end\0Aa,b = g()\0Aassert(a==1 and b==nil)\0A\0Aprint'+';\0A\0Ado   -- testing constants\0A  local prog <const> = [[local x <XXX> = 10]]\0A  checkload(prog, \22unknown attribute 'XXX'\22)\0A\0A  checkload([[local xxx <const> = 20; xxx = 10]],\0A             \22:1: attempt to assign to const variable 'xxx'\22)\0A\0A  checkload([[\0A    local xx;\0A    local xxx <const> = 20;\0A    local yyy;\0A    local function foo ()\0A      local abc = xx + yyy + xxx;\0A      return function () return function () xxx = yyy end end\0A    end\0A  ]], \22:6: attempt to assign to const variable 'xxx'\22)\0A\0A  checkload([[\0A    local x <close> = nil\0A    x = io.open()\0A  ]], \22:2: attempt to assign to const variable 'x'\22)\0Aend\0A\0Af = [[\0Areturn function ( a , b , c , d , e )\0A  local x = a >= b or c or ( d and e ) or nil\0A  return x\0Aend , { a = 1 , b = 2 >= 1 , } or { 1 };\0A]]\0Af = string.gsub(f, \22%s+\22, \22\\n\22);   -- force a SETLINE between opcodes\0Af,a = load(f)();\0Aassert(a.a == 1 and a.b)\0A\0Afunction g (a,b,c,d,e)\0A  if not (a>=b or c or d and e or nil) then return 0; else return 1; end;\0Aend\0A\0Alocal function h (a,b,c,d,e)\0A  while (a>=b or c or (d and e) or nil) do return 1; end;\0A  return 0;\0Aend;\0A\0Aassert(f(2,1) == true and g(2,1) == 1 and h(2,1) == 1)\0Aassert(f(1,2,'a') == 'a' and g(1,2,'a') == 1 and h(1,2,'a') == 1)\0Aassert(f(1,2,'a')\0A~=          -- force SETLINE before nil\0Anil, \22\22)\0Aassert(f(1,2,'a') == 'a' and g(1,2,'a') == 1 and h(1,2,'a') == 1)\0Aassert(f(1,2,nil,1,'x') == 'x' and g(1,2,nil,1,'x') == 1 and\0A                                   h(1,2,nil,1,'x') == 1)\0Aassert(f(1,2,nil,nil,'x') == nil and g(1,2,nil,nil,'x') == 0 and\0A                                     h(1,2,nil,nil,'x') == 0)\0Aassert(f(1,2,nil,1,nil) == nil and g(1,2,nil,1,nil) == 0 and\0A                                   h(1,2,nil,1,nil) == 0)\0A\0Aassert(1 and 2<3 == true and 2<3 and 'a'<'b' == true)\0Ax = 2<3 and not 3; assert(x==false)\0Ax = 2<1 or (2>1 and 'a'); assert(x=='a')\0A\0A\0Ado\0A  local a; if nil then a=1; else a=2; end;    -- this nil comes as PUSHNIL 2\0A  assert(a==2)\0Aend\0A\0Alocal function F (a)\0A  assert(debug.getinfo(1, \22n\22).name == 'F')\0A  return a,2,3\0Aend\0A\0Aa,b = F(1)~=nil; assert(a == true and b == nil);\0Aa,b = F(nil)==nil; assert(a == true and b == nil)\0A\0A----------------------------------------------------------------\0A------------------------------------------------------------------\0A\0A-- sometimes will be 0, sometimes will not...\0A_ENV.GLOB1 = math.random(0, 1)\0A\0A-- basic expressions with their respective values\0Alocal basiccases = {\0A  {\22nil\22, nil},\0A  {\22false\22, false},\0A  {\22true\22, true},\0A  {\2210\22, 10},\0A  {\22(0==_ENV.GLOB1)\22, 0 == _ENV.GLOB1},\0A}\0A\0Alocal prog\0A\0Aif _ENV.GLOB1 == 0 then\0A  basiccases[2][1] = \22F\22   -- constant false\0A\0A  prog = [[\0A    local F <const> = false\0A    if %s then IX = true end\0A    return %s\0A]]\0Aelse\0A  basiccases[4][1] = \22k10\22   -- constant 10\0A\0A  prog = [[\0A    local k10 <const> = 10\0A    if %s then IX = true end\0A    return %s\0A  ]]\0Aend\0A\0Aprint('testing short-circuit optimizations (' .. _ENV.GLOB1 .. ')')\0A\0A\0A-- operators with their respective values\0Alocal binops <const> = {\0A  {\22 and \22, function (a,b) if not a then return a else return b end end},\0A  {\22 or \22, function (a,b) if a then return a else return b end end},\0A}\0A\0Alocal cases <const> = {}\0A\0A-- creates all combinations of '(cases[i] op cases[n-i])' plus\0A-- 'not(cases[i] op cases[n-i])' (syntax + value)\0Alocal function createcases (n)\0A  local res = {}\0A  for i = 1, n - 1 do\0A    for _, v1 in ipairs(cases[i]) do\0A      for _, v2 in ipairs(cases[n - i]) do\0A        for _, op in ipairs(binops) do\0A            local t = {\0A              \22(\22 .. v1[1] .. op[1] .. v2[1] .. \22)\22,\0A              op[2](v1[2], v2[2])\0A            }\0A            res[#res + 1] = t\0A            res[#res + 1] = {\22not\22 .. t[1], not t[2]}\0A        end\0A      end\0A    end\0A  end\0A  return res\0Aend\0A\0A-- do not do too many combinations for soft tests\0Alocal level = _soft and 3 or 4\0A\0Acases[1] = basiccases\0Afor i = 2, level do cases[i] = createcases(i) end\0Aprint(\22+\22)\0A\0Alocal i = 0\0Afor n = 1, level do\0A  for _, v in pairs(cases[n]) do\0A    local s = v[1]\0A    local p = load(string.format(prog, s, s), \22\22)\0A    IX = false\0A    assert(p() == v[2] and IX == not not v[2])\0A    i = i + 1\0A    if i % 60000 == 0 then print('+') end\0A  end\0Aend\0AIX = nil\0A_G.GLOB1 = nil\0A------------------------------------------------------------------\0A\0A-- testing some syntax errors (chosen through 'gcov')\0Acheckload(\22for x do\22, \22expected\22)\0Acheckload(\22x:call\22, \22expected\22)\0A\0Aprint'OK'\0A", align 16
@t16 = internal constant [29043 x i8] c"-- $Id: testes/locals.lua $\0A-- See Copyright Notice in file all.lua\0A\0Aprint('testing local variables and environments')\0A\0Alocal debug = require\22debug\22\0A\0Alocal tracegc = require\22tracegc\22\0A\0A\0A-- bug in 5.1:\0A\0Alocal function f(x) x = nil; return x end\0Aassert(f(10) == nil)\0A\0Alocal function f() local x; return x end\0Aassert(f(10) == nil)\0A\0Alocal function f(x) x = nil; local y; return x, y end\0Aassert(f(10) == nil and select(2, f(20)) == nil)\0A\0Ado\0A  local i = 10\0A  do local i = 100; assert(i==100) end\0A  do local i = 1000; assert(i==1000) end\0A  assert(i == 10)\0A  if i ~= 10 then\0A    local i = 20\0A  else\0A    local i = 30\0A    assert(i == 30)\0A  end\0Aend\0A\0A\0A\0Af = nil\0A\0Alocal f\0Alocal x = 1\0A\0Aa = nil\0Aload('local a = {}')()\0Aassert(a == nil)\0A\0Afunction f (a)\0A  local _1, _2, _3, _4, _5\0A  local _6, _7, _8, _9, _10\0A  local x = 3\0A  local b = a\0A  local c,d = a,b\0A  if (d == b) then\0A    local x = 'q'\0A    x = b\0A    assert(x == 2)\0A  else\0A    assert(nil)\0A  end\0A  assert(x == 3)\0A  local f = 10\0Aend\0A\0Alocal b=10\0Alocal a; repeat local b; a,b=1,2; assert(a+1==b); until a+b==3\0A\0A\0Aassert(x == 1)\0A\0Af(2)\0Aassert(type(f) == 'function')\0A\0A\0Alocal function getenv (f)\0A  local a,b = debug.getupvalue(f, 1)\0A  assert(a == '_ENV')\0A  return b\0Aend\0A\0A-- test for global table of loaded chunks\0Aassert(getenv(load\22a=3\22) == _G)\0Alocal c = {}; local f = load(\22a = 3\22, nil, nil, c)\0Aassert(getenv(f) == c)\0Aassert(c.a == nil)\0Af()\0Aassert(c.a == 3)\0A\0A-- old test for limits for special instructions\0Ado\0A  local i = 2\0A  local p = 4    -- p == 2^i\0A  repeat\0A    for j=-3,3 do\0A      assert(load(string.format([[local a=%s;\0A                                        a=a+%s;\0A                                        assert(a ==2^%s)]], j, p-j, i), '')) ()\0A      assert(load(string.format([[local a=%s;\0A                                        a=a-%s;\0A                                        assert(a==-2^%s)]], -j, p-j, i), '')) ()\0A      assert(load(string.format([[local a,b=0,%s;\0A                                        a=b-%s;\0A                                        assert(a==-2^%s)]], -j, p-j, i), '')) ()\0A    end\0A    p = 2 * p;  i = i + 1\0A  until p <= 0\0Aend\0A\0Aprint'+'\0A\0A\0Aif rawget(_G, \22T\22) then\0A  -- testing clearing of dead elements from tables\0A  collectgarbage(\22stop\22)   -- stop GC\0A  local a = {[{}] = 4, [3] = 0, alo = 1,\0A             a1234567890123456789012345678901234567890 = 10}\0A\0A  local t = T.querytab(a)\0A\0A  for k,_ in pairs(a) do a[k] = undef end\0A  collectgarbage()   -- restore GC and collect dead fields in 'a'\0A  for i=0,t-1 do\0A    local k = querytab(a, i)\0A    assert(k == nil or type(k) == 'number' or k == 'alo')\0A  end\0A\0A  -- testing allocation errors during table insertions\0A  local a = {}\0A  local function additems ()\0A    a.x = true; a.y = true; a.z = true\0A    a[1] = true\0A    a[2] = true\0A  end\0A  for i = 1, math.huge do\0A    T.alloccount(i)\0A    local st, msg = pcall(additems)\0A    T.alloccount()\0A    local count = 0\0A    for k, v in pairs(a) do\0A      assert(a[k] == v)\0A      count = count + 1\0A    end\0A    if st then assert(count == 5); break end\0A  end\0Aend\0A\0A\0A-- testing lexical environments\0A\0Aassert(_ENV == _G)\0A\0Ado\0Alocal dummy\0Alocal _ENV = (function (...) return ... end)(_G, dummy)   -- {\0A\0Ado local _ENV = {assert=assert}; assert(true) end\0Alocal mt = {_G = _G}\0Alocal foo,x\0AA = false    -- \22declare\22 A\0Ado local _ENV = mt\0A  function foo (x)\0A    A = x\0A    do local _ENV =  _G; A = 1000 end\0A    return function (x) return A .. x end\0A  end\0Aend\0Aassert(getenv(foo) == mt)\0Ax = foo('hi'); assert(mt.A == 'hi' and A == 1000)\0Aassert(x('*') == mt.A .. '*')\0A\0Ado local _ENV = {assert=assert, A=10};\0A  do local _ENV = {assert=assert, A=20};\0A    assert(A==20);x=A\0A  end\0A  assert(A==10 and x==20)\0Aend\0Aassert(x==20)\0A\0AA = nil\0A\0A\0Ado   -- constants\0A  local a<const>, b, c<const> = 10, 20, 30\0A  b = a + c + b    -- 'b' is not constant\0A  assert(a == 10 and b == 60 and c == 30)\0A  local function checkro (name, code)\0A    local st, msg = load(code)\0A    local gab = string.format(\22attempt to assign to const variable '%s'\22, name)\0A    assert(not st and string.find(msg, gab))\0A  end\0A  checkro(\22y\22, \22local x, y <const>, z = 10, 20, 30; x = 11; y = 12\22)\0A  checkro(\22x\22, \22local x <const>, y, z <const> = 10, 20, 30; x = 11\22)\0A  checkro(\22z\22, \22local x <const>, y, z <const> = 10, 20, 30; y = 10; z = 11\22)\0A  checkro(\22foo\22, \22local foo <const> = 10; function foo() end\22)\0A  checkro(\22foo\22, \22local foo <const> = {}; function foo() end\22)\0A\0A  checkro(\22z\22, [[\0A    local a, z <const>, b = 10;\0A    function foo() a = 20; z = 32; end\0A  ]])\0A\0A  checkro(\22var1\22, [[\0A    local a, var1 <const> = 10;\0A    function foo() a = 20; z = function () var1 = 12; end  end\0A  ]])\0Aend\0A\0A\0Aprint\22testing to-be-closed variables\22\0A\0Alocal function stack(n) n = ((n == 0) or stack(n - 1)) end\0A\0Alocal function func2close (f, x, y)\0A  local obj = setmetatable({}, {__close = f})\0A  if x then\0A    return x, obj, y\0A  else\0A    return obj\0A  end\0Aend\0A\0A\0Ado\0A  local a = {}\0A  do\0A    local b <close> = false   -- not to be closed\0A    local x <close> = setmetatable({\22x\22}, {__close = function (self)\0A                                                   a[#a + 1] = self[1] end})\0A    local w, y <close>, z = func2close(function (self, err)\0A                                assert(err == nil); a[#a + 1] = \22y\22\0A                              end, 10, 20)\0A    local c <close> = nil  -- not to be closed\0A    a[#a + 1] = \22in\22\0A    assert(w == 10 and z == 20)\0A  end\0A  a[#a + 1] = \22out\22\0A  assert(a[1] == \22in\22 and a[2] == \22y\22 and a[3] == \22x\22 