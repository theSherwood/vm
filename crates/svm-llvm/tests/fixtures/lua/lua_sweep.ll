0A  local a, b, c = co()\0A  assert(a and b == 10 and c == 20)   -- returns from 'pcall(foo, nil)'\0A\0A  local a, b = co()   -- second foo: error in __close\0A  assert(a == \22x\22 and b == nil)    -- yields inside 'x'; Ok\0A  a, b = co()\0A  assert(a == \22y\22 and b == nil)    -- yields inside 'y'; Ok\0A  a, b = co()\0A  assert(a == \22z\22 and b == nil)    -- yields inside 'z'; Ok\0A  local st, msg = co()             -- reports the error in 'y'\0A  assert(not st and msg == 21)\0A\0A  local a, b = co()    -- third foo: error in function body\0A  assert(a == \22x\22 and b == nil)    -- yields inside 'x'; Ok\0A  a, b = co()\0A  assert(a == \22y\22 and b == nil)    -- yields inside 'y'; Ok\0A  a, b = co()\0A  assert(a == \22z\22 and b == nil)    -- yields inside 'z'; Ok\0A  local st, msg = co()    -- gets final error\0A  assert(not st and msg == 10 + 20)\0A\0Aend\0A\0A\0Ado\0A  -- an error in a wrapped coroutine closes variables\0A  local x = false\0A  local y = false\0A  local co = coroutine.wrap(function ()\0A    local xv <close> = func2close(function () x = true end)\0A    do\0A      local yv <close> = func2close(function () y = true end)\0A      coroutine.yield(100)   -- yield doesn't close variable\0A    end\0A    coroutine.yield(200)   -- yield doesn't close variable\0A    error(23)              -- error does\0A  end)\0A\0A  local b = co()\0A  assert(b == 100 and not x and not y)\0A  b = co()\0A  assert(b == 200 and not x and y)\0A  local a, b = pcall(co)\0A  assert(not a and b == 23 and x and y)\0Aend\0A\0A\0Ado\0A\0A  -- error in a wrapped coroutine raising errors when closing a variable\0A  local x = 0\0A  local co = coroutine.wrap(function ()\0A    local xx <close> = func2close(function (_, msg)\0A      x = x + 1;\0A      assert(string.find(msg, \22@XXX\22))\0A      error(\22@YYY\22)\0A    end)\0A    local xv <close> = func2close(function () x = x + 1; error(\22@XXX\22) end)\0A    coroutine.yield(100)\0A    error(200)\0A  end)\0A  assert(co() == 100); assert(x == 0)\0A  local st, msg = pcall(co); assert(x == 2)\0A  assert(not st and string.find(msg, \22@YYY\22))   -- should get error raised\0A\0A  local x = 0\0A  local y = 0\0A  co = coroutine.wrap(function ()\0A    local xx <close> = func2close(function (_, err)\0A      y = y + 1;\0A      assert(string.find(err, \22XXX\22))\0A      error(\22YYY\22)\0A    end)\0A    local xv <close> = func2close(function ()\0A      x = x + 1; error(\22XXX\22)\0A    end)\0A    coroutine.yield(100)\0A    return 200\0A  end)\0A  assert(co() == 100); assert(x == 0)\0A  local st, msg = pcall(co)\0A  assert(x == 1 and y == 1)\0A  -- should get first error raised\0A  assert(not st and string.find(msg, \22%w+%.%w+:%d+: YYY\22))\0A\0Aend\0A\0A\0A-- a suspended coroutine should not close its variables when collected\0Alocal co\0Aco = coroutine.wrap(function()\0A  -- should not run\0A  local x <close> = func2close(function () os.exit(false) end)\0A  co = nil\0A  coroutine.yield()\0Aend)\0Aco()                 -- start coroutine\0Aassert(co == nil)    -- eventually it will be collected\0Acollectgarbage()\0A\0A\0Aif rawget(_G, \22T\22) then\0A  print(\22to-be-closed variables x coroutines in C\22)\0A  do\0A    local token = 0\0A    local count = 0\0A    local f = T.makeCfunc[[\0A      toclose 1\0A      toclose 2\0A      return .\0A    ]]\0A\0A    local obj = func2close(function (_, msg)\0A      count = count + 1\0A      token = coroutine.yield(count, token)\0A    end)\0A\0A    local co = coroutine.wrap(f)\0A    local ct, res = co(obj, obj, 10, 20, 30, 3)   -- will return 10, 20, 30\0A    -- initial token value, after closing 2nd obj\0A    assert(ct == 1 and res == 0)\0A    -- run until yield when closing 1st obj\0A    ct, res = co(100)\0A    assert(ct == 2 and res == 100)\0A    res = {co(200)}      -- run until end\0A    assert(res[1] == 10 and res[2] == 20 and res[3] == 30 and res[4] == nil)\0A    assert(token == 200)\0A  end\0A\0A  do\0A    local f = T.makeCfunc[[\0A      toclose 1\0A      retu