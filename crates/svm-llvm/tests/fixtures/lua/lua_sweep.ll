@t17 = internal constant [5393 x i8] c"-- $Id: testes/cstack.lua $\0A-- See Copyright Notice in file all.lua\0A\0A\0Alocal tracegc = require\22tracegc\22\0A\0Aprint\22testing stack overflow detection\22\0A\0A-- Segmentation faults in these tests probably result from a C-stack\0A-- overflow. To avoid these errors, you should set a smaller limit for\0A-- the use of C stack by Lua, by changing the constant 'LUAI_MAXCCALLS'.\0A-- Alternatively, you can ensure a larger stack for the program.\0A\0A\0Alocal function checkerror (msg, f, ...)\0A  local s, err = pcall(f, ...)\0A  assert(not s and string.find(err, msg))\0Aend\0A\0Ado  print(\22testing stack overflow in message handling\22)\0A  local count = 0\0A  local function loop (x, y, z)\0A    count = count + 1\0A    return 1 + loop(x, y, z)\0A  end\0A  tracegc.stop()    -- __gc should not be called with a full stack\0A  local res, msg = xpcall(loop, loop)\0A  tracegc.start()\0A  assert(msg == \22error in error handling\22)\0A  print(\22final count: \22, count)\0Aend\0A\0A\0A-- bug since 2.5 (C-stack overflow in recursion inside pattern matching)\0Ado  print(\22testing recursion inside pattern matching\22)\0A  local function f (size)\0A    local s = string.rep(\22a\22, size)\0A    local p = string.rep(\22.?\22, size)\0A    return string.match(s, p)\0A  end\0A  local m = f(80)\0A  assert(#m == 80)\0A  checkerror(\22too complex\22, f, 2000)\0Aend\0A\0A\0Ado  print(\22testing stack-overflow in recursive 'gsub'\22)\0A  local count = 0\0A  local function foo ()\0A    count = count + 1\0A    string.gsub(\22a\22, \22.\22, foo)\0A  end\0A  checkerror(\22stack overflow\22, foo)\0A  print(\22final count: \22, count)\0A\0A  print(\22testing stack-overflow in recursive 'gsub' with metatables\22)\0A  local count = 0\0A  local t = setmetatable({}, {__index = foo})\0A  foo = function ()\0A    count = count + 1\0A    string.gsub(\22a\22, \22.\22, t)\0A  end\0A  checkerror(\22stack overflow\22, foo)\0A  print(\22final count: \22, count)\0Aend\0A\0A\0Ado   -- bug in 5.4.0\0A  print(\22testing limits in coroutines inside deep calls\22)\0A  local count = 0\0A  local lim = 1000\0A  local function stack (n)\0A    if n > 0 then return stack(n - 1) + 1\0A    else coroutine.wrap(function ()\0A           count = count + 1\0A           stack(lim)\0A         end)()\0A    end\0A  end\0A\0A  local st, msg = xpcall(stack, function () return \22ok\22 end, lim)\0A  assert(not st and msg == \22ok\22)\0A  print(\22final count: \22, count)\0Aend\0A\0A\0Ado    -- bug since 5.4.0\0A  local count = 0\0A  print(\22chain of 'coroutine.close'\22)\0A  -- create N coroutines forming a list so that each one, when closed,\0A  -- closes the previous one. (With a large enough N, previous Lua\0A  -- versions crash in this test.)\0A  local coro = false\0A  for i = 1, 1000 do\0A    local previous = coro\0A    coro = coroutine.create(function()\0A      local cc <close> = setmetatable({}, {__close=function()\0A        count = count + 1\0A        if previous then\0A          assert(coroutine.close(previous))\0A        end\0A      end})\0A      coroutine.yield()   -- leaves 'cc' pending to be closed\0A    end)\0A    assert(coroutine.resume(coro))  -- start it and run until it yields\0A  end\0A  local st, msg = coroutine.close(coro)\0A  assert(not st and string.find(msg, \22C stack overflow\22))\0A  print(\22final count: \22, count)\0Aend\0A\0A\0Ado\0A  print(\22nesting of resuming yielded coroutines\22)\0A  local count = 0\0A\0A  local function body ()\0A    coroutine.yield()\0A    local f = coroutine.wrap(body)\0A    f();  -- start new coroutine (will stop in previous yield)\0A    count = count + 1\0A    f()   -- call it recursively\0A  end\0A\0A  local f = coroutine.wrap(body)\0A  f()\0A  assert(not pcall(f))\0A  print(\22final count: \22, count)\0Aend\0A\0A\0Ado    -- bug in 5.4.2\0A  print(\22nesting coroutines running after recoverable errors\22)\0A  local count = 0\0A  local function foo()\0A    count = count + 1\0A    pcall(1)   -- create an error\0A    -- running now inside 'precover' (\22protected recover\22)\0A    coroutine.wrap(foo)()   -- call another coroutine\0A  end\0A  checkerror(\22C stack overflow\22, foo)\0A  print(\22final count: \22, count)\0Aend\0A\0A\0Aif T then\0A  print(\22testing stack recovery\22)\0A  local N = 0      -- trace number of calls\0A  local LIM = -1   -- will store N just before stack overflow\0A\0A  -- trace stack size; after stack overflow, it should be\0A  -- the maximum allowed stack size.\0A  local stack1\0A  local dummy\0A\0A  local function err(msg)\0A    assert(string.find(msg, \22stack overflow\22))\0A    local _, stacknow = T.stacklevel()\0A    assert(stacknow == stack1 + 200)\0A  end\0A\0A  -- When LIM==-1, the 'if' is not executed, so this function only\0A  -- counts and stores the stack limits up to overflow.  Then, LIM\0A  -- becomes N, and then the 'if' code is run when the stack is\0A  -- full. Then, there is a stack overflow inside 'xpcall', after which\0A  -- the stack must have been restored back to its maximum normal size.\0A  local function f()\0A    dummy, stack1 = T.stacklevel()\0A    if N == LIM then\0A      xpcall(f, err)\0A      local _, stacknow = T.stacklevel()\0A      assert(stacknow == stack1)\0A      return\0A    end\0A    N = N + 1\0A    f()\0A  end\0A\0A  local topB, sizeB   -- top and size Before overflow\0A  local topA, sizeA   -- top and size After overflow\0A  topB, sizeB = T.stacklevel()\0A  tracegc.stop()    -- __gc should not be called with a full stack\0A  xpcall(f, err)\0A  tracegc.start()\0A  topA, sizeA = T.stacklevel()\0A  -- sizes should be comparable\0A  assert(topA == topB and sizeA < sizeB * 2)\0A  print(string.format(\22maximum stack size: %d\22, stack1))\0A  LIM = N      -- will stop recursion at maximum level\0A  N = 0        -- to count again\0A  tracegc.stop()    -- __gc should not be called with a full stack\0A  f()\0A  tracegc.start()\0A  print\22+\22\0Aend\0A\0Aprint'OK'\0A", align 16
@t18 = internal constant [18389 x i8] c"-- $Id: testes/strings.lua $\0A-- See Copyright Notice in file all.lua\0A\0A-- ISO Latin encoding\0A\0A\0Aprint('testing strings and string library')\0A\0Alocal maxi <const> = math.maxinteger\0Alocal mini <const> = math.mininteger\0A\0A\0Alocal function checkerror (msg, f, ...)\0A  local s, err = pcall(f, ...)\0A  assert(not s and string.find(err, msg))\0Aend\0A\0A\0A-- testing string comparisons\0Aassert('alo' < 'alo1')\0Aassert('' < 'a')\0Aassert('alo\\0alo' < 'alo\\0b')\0Aassert('alo\\0alo\\0\\0' > 'alo\\0alo\\0')\0Aassert('alo' < 'alo\\0')\0Aassert('alo\\0' > 'alo')\0Aassert('\\0' < '\\1')\0Aassert('\\0\\0' < '\\0\\1')\0Aassert('\\1\\0a\\0a' <= '\\1\\0a\\0a')\0Aassert(not ('\\1\\0a\\0b' <= '\\1\\0a\\0a'))\0Aassert('\\0\\0\\0' < '\\0\\0\\0\\0')\0Aassert(not('\\0\\0\\0\\0' < '\\0\\0\\0'))\0Aassert('\\0\\0\\0' <= '\\0\\0\\0\\0')\0Aassert(not('\\0\\0\\0\\0' <= '\\0\\0\\0'))\0Aassert('\\0\\0\\0' <= '\\0\\0\\0')\0Aassert('\\0\\0\\0' >= '\\0\\0\\0')\0Aassert(not ('\\0\\0b' < '\\0\\0a\\0'))\0A\0A-- testing string.sub\0Aassert(string.sub(\22123456789\22,2,4) == \22234\22)\0Aassert(string.sub(\22123456789\22,7) == \22789\22)\0Aassert(string.sub(\22123456789\22,7,6) == \22\22)\0Aassert(string.sub(\22123456789\22,7,7) == \227\22)\0Aassert(string.sub(\22123456789\22,0,0) == \22\22)\0Aassert(string.sub(\22123456789\22,-10,10) == \22123456789\22)\0Aassert(string.sub(\22123456789\22,1,9) == \22123456789\22)\0Aassert(string.sub(\22123456789\22,-10,-20) == \22\22)\0Aassert(string.sub(\22123456789\22,-1) == \229\22)\0Aassert(string.sub(\22123456789\22,-4) == \226789\22)\0Aassert(string.sub(\22123456789\22,-6, -4) == \22456\22)\0Aassert(string.sub(\22123456789\22, mini, -4) == \22123456\22)\0Aassert(string.sub(\22123456789\22, mini, maxi) == \22123456789\22)\0Aassert(string.sub(\22123456789\22, mini, mini) == \22\22)\0Aassert(string.sub(\22\\000123456789\22,3,5) == \22234\22)\0Aassert((\22\\000123456789\22):sub(8) == \22789\22)\0A\0A-- testing string.find\0Aassert(string.find(\22123456789\22, \22345\22) == 3)\0Alocal a,b = string.find(\22123456789\22, \22345\22)\0Aassert(string.sub(\22123456789\22, a, b) == \22345\22)\0Aassert(string.find(\221234567890123456789\22, \22345\22, 3) == 3)\0Aassert(string.find(\221234567890123456789\22, \22345\22, 4) == 13)\0Aassert(not string.find(\221234567890123456789\22, \22346\22, 4))\0Aassert(string.find(\221234567890123456789\22, \22.45\22, -9) == 13)\0Aassert(not string.find(\22abcdefg\22, \22\\0\22, 5, 1))\0Aassert(string.find(\22\22, \22\22) == 1)\0Aassert(string.find(\22\22, \22\22, 1) == 1)\0Aassert(not string.find(\22\22, \22\22, 2))\0Aassert(not string.find('', 'aaa', 1))\0Aassert(('alo(.)alo'):find('(.)', 1, 1) == 4)\0A\0Aassert(string.len(\22\22) == 0)\0Aassert(string.len(\22\\0\\0\\0\22) == 3)\0Aassert(string.len(\221234567890\22) == 10)\0A\0Aassert(#\22\22 == 0)\0Aassert(#\22\\0\\0\\0\22 == 3)\0Aassert(#\221234567890\22 == 10)\0A\0A-- testing string.byte/string.char\0Aassert(string.byte(\22a\22) == 97)\0Aassert(string.byte(\22\\xe4\22) > 127)\0Aassert(string.byte(string.char(255)) == 255)\0Aassert(string.byte(string.char(0)) == 0)\0Aassert(string.byte(\22\\0\22) == 0)\0Aassert(string.byte(\22\\0\\0alo\\0x\22, -1) == string.byte('x'))\0Aassert(string.byte(\22ba\22, 2) == 97)\0Aassert(string.byte(\22\\n\\n\22, 2, -1) == 10)\0Aassert(string.byte(\22\\n\\n\22, 2, 2) == 10)\0Aassert(string.byte(\22\22) == nil)\0Aassert(string.byte(\22hi\22, -3) == nil)\0Aassert(string.byte(\22hi\22, 3) == nil)\0Aassert(string.byte(\22hi\22, 9, 10) == nil)\0Aassert(string.byte(\22hi\22, 2, 1) == nil)\0Aassert(string.char() == \22\22)\0Aassert(string.char(0, 255, 0) == \22\\0\\255\\0\22)\0Aassert(string.char(0, string.byte(\22\\xe4\22), 0) == \22\\0\\xe4\\0\22)\0Aassert(string.char(string.byte(\22\\xe4l\\0\F3u\22, 1, -1)) == \22\\xe4l\\0\F3u\22)\0Aassert(string.char(string.byte(\22\\xe4l\\0\F3u\22, 1, 0)) == \22\22)\0Aassert(string.char(string.byte(\22\\xe4l\\0\F3u\22, -10, 100)) == \22\\xe4l\\0\F3u\22)\0A\0Acheckerror(\22out of range\22, string.char, 256)\0Acheckerror(\22out of range\22, string.char, -1)\0Acheckerror(\22out of range\22, string.char, math.maxinteger)\0Acheckerror(\22out of range\22, string.char, math.mininteger)\0A\0Aassert(string.upper(\22ab\\0c\22) == \22AB\\0C\22)\0Aassert(string.lower(\22\\0ABCc%$\22) == \22\\0abcc%$\22)\0Aassert(string.rep('teste', 0) == '')\0Aassert(string.rep('t\E9s\\00t\EA', 2) == 't\E9s\\0t\EAt\E9s\\000t\EA')\0Aassert(string.rep('', 10) == '')\0A\0Aif string.packsize(\22i\22) == 4 then\0A  -- result length would be 2^31 (int overflow)\0A  checkerror(\22too large\22, string.rep, 'aa', (1 << 30))\0A  checkerror(\22too large\22, string.rep, 'a', (1 << 30), ',')\0Aend\0A\0A-- repetitions with separator\0Aassert(string.rep('teste', 0, 'xuxu') == '')\0Aassert(string.rep('teste', 1, 'xuxu') == 'teste')\0Aassert(string.rep('\\1\\0\\1', 2, '\\0\\0') == '\\1\\0\\1\\0\\0\\1\\0\\1')\0Aassert(string.rep('', 10, '.') == string.rep('.', 9))\0Aassert(not pcall(string.rep, \22aa\22, maxi // 2 + 10))\0Aassert(not pcall(string.rep, \22\22, maxi // 2 + 10, \22aa\22))\0A\0Aassert(string.reverse\22\22 == \22\22)\0Aassert(string.reverse\22\\0\\1\\2\\3\22 == \22\\3\\2\\1\\0\22)\0Aassert(string.reverse\22\\0001234\22 == \224321\\0\22)\0A\0Afor i=0,30 do assert(string.len(string.rep('a', i)) == i) end\0A\0Aassert(type(tostring(nil)) == 'string')\0Aassert(type(tostring(12)) == 'string')\0Aassert(string.find(tostring{}, 'table:'))\0Aassert(string.find(tostring(print), 'function:'))\0Aassert(#tostring('\\0') == 1)\0Aassert(tostring(true) == \22true\22)\0Aassert(tostring(false) == \22false\22)\0Aassert(tostring(-1203) == \22-1203\22)\0Aassert(tostring(1203.125) == \221203.125\22)\0Aassert(tostring(-0.5) == \22-0.5\22)\0Aassert(tostring(-32767) == \22-32767\22)\0Aif math.tointeger(2147483647) then   -- no overflow? (32 bits)\0A  assert(tostring(-2147483647) == \22-2147483647\22)\0Aend\0Aif math.tointeger(4611686018427387904) then   -- no overflow? (64 bits)\0A  assert(tostring(4611686018427387904) == \224611686018427387904\22)\0A  assert(tostring(-4611686018427387904) == \22-4611686018427387904\22)\0Aend\0A\0Aif tostring(0.0) == \220.0\22 then   -- \22standard\22 coercion float->string\0A  assert('' .. 12 == '12' and 12.0 .. '' == '12.0')\0A  assert(tostring(-1203 + 0.0) == \22-1203.0\22)\0Aelse   -- compatible coercion\0A  assert(tostring(0.0) == \220\22)\0A  assert('' .. 12 == '12' and 12.0 .. '' == '12')\0A  assert(tostring(-1203 + 0.0) == \22-1203\22)\0Aend\0A\0Ado  -- tests for '%p' format\0A  -- not much to test, as C does not specify what '%p' does.\0A  -- (\22The value of the pointer is converted to a sequence of printing\0A  -- characters, in an implementation-defined manner.\22)\0A  local null = \22(null)\22    -- nulls are formatted by Lua\0A  assert(string.format(\22%p\22, 4) == null)\0A  assert(string.format(\22%p\22, true) == null)\0A  assert(string.format(\22%p\22, nil) == null)\0A  assert(string.format(\22%p\22, {}) ~= null)\0A  assert(string.format(\22%p\22, print) ~= null)\0A  assert(string.format(\22%p\22, coroutine.running()) ~= null)\0A  assert(string.format(\22%p\22, io.stdin) ~= null)\0A  assert(string.format(\22%p\22, io.stdin) == string.format(\22%p\22, io.stdin))\0A  assert(string.format(\22%p\22, print) == string.format(\22%p\22, print))\0A  assert(string.format(\22%p\22, print) ~= string.format(\22%p\22, assert))\0A\0A  assert(#string.format(\22%90p\22, {}) == 90)\0A  assert(#string.format(\22%-60p\22, {}) == 60)\0A  assert(string.format(\22%10p\22, false) == string.rep(\22 \22, 10 - #null) .. null)\0A  assert(string.format(\22%-12p\22, 1.5) == null .. string.rep(\22 \22, 12 - #null))\0A\0A  do\0A    local t1 = {}; local t2 = {}\0A    assert(string.format(\22%p\22, t1) ~= string.format(\22%p\22, t2))\0A  end\0A\0A  do     -- short strings are internalized\0A    local s1 = string.rep(\22a\22, 10)\0A    local s2 = string.rep(\22aa\22, 5)\0A  assert(string.format(\22%p\22, s1) == string.format(\22%p\22, s2))\0A  end\0A\0A  do     -- long strings aren't internalized\0A    local s1 = string.rep(\22a\22, 300); local s2 = string.rep(\22a\22, 300)\0A    assert(string.format(\22%p\22, s1) ~= string.format(\22%p\22, s2))\0A  end\0Aend\0A\0Alocal x = '\22\EDlo\22\\n\\\\'\0Aassert(string.format('%q%s', x, x) == '\22\\\\\22\EDlo\\\\\22\\\\\\n\\\\\\\\\22\22\EDlo\22\\n\\\\')\0Aassert(string.format('%q', \22\\0\22) == [[\22\\0\22]])\0Aassert(load(string.format('return %q', x))() == x)\0Ax = \22\\0\\1\\0023\\5\\0009\22\0Aassert(load(string.format('return %q', x))() == x)\0Aassert(string.format(\22\\0%c\\0%c%x\\0\22, string.byte(\22\\xe4\22), string.byte(\22b\22), 140) ==\0A              \22\\0\\xe4\\0b8c\\0\22)\0Aassert(string.format('') == \22\22)\0Aassert(string.format(\22%c\22,34)..string.format(\22%c\22,48)..string.format(\22%c\22,90)..string.format(\22%c\22,100) ==\0A       string.format(\22%1c%-c%-1c%c\22, 34, 48, 90, 100))\0Aassert(string.format(\22%s\\0 is not \\0%s\22, 'not be', 'be') == 'not be\\0 is not \\0be')\0Aassert(string.format(\22%%%d %010d\22, 10, 23) == \22%10 0000000023\22)\0Aassert(tonumber(string.format(\22%f\22, 10.3)) == 10.3)\0Aassert(string.format('\22%-50s\22', 'a') == '\22a' .. string.rep(' ', 49) .. '\22')\0A\0Aassert(string.format(\22-%.20s.20s\22, string.rep(\22%\22, 2000)) ==\0A                     \22-\22..string.rep(\22%\22, 20)..\22.20s\22)\0Aassert(string.format('\22-%20s.20s\22', string.rep(\22%\22, 2000)) ==\0A       string.format(\22%q\22, \22-\22..string.rep(\22%\22, 2000)..\22.20s\22))\0A\0Ado\0A  local function checkQ (v)\0A    local s = string.format(\22%q\22, v)\0A    local nv = load(\22return \22 .. s)()\0A    assert(v == nv and math.type(v) == math.type(nv))\0A  end\0A  checkQ(\22\\0\\0\\1\\255\\u{234}\22)\0A  checkQ(math.maxinteger)\0A  checkQ(math.mininteger)\0A  checkQ(math.pi)\0A  checkQ(0.1)\0A  checkQ(true)\0A  checkQ(nil)\0A  checkQ(false)\0A  checkQ(math.huge)\0A  checkQ(-math.huge)\0A  assert(string.format(\22%q\22, 0/0) == \22(0/0)\22)   -- NaN\0A  checkerror(\22no literal\22, string.format, \22%q\22, {})\0Aend\0A\0Aassert(string.format(\22\\0%s\\0\22, \22\\0\\0\\1\22) == \22\\0\\0\\0\\1\\0\22)\0Acheckerror(\22contains zeros\22, string.format, \22%10s\22, \22\\0\22)\0A\0A-- format x tostring\0Aassert(string.format(\22%s %s\22, nil, true) == \22nil true\22)\0Aassert(string.format(\22%s %.4s\22, false, true) == \22false true\22)\0Aassert(string.format(\22%.3s %.3s\22, false, true) == \22fal tru\22)\0Alocal m = setmetatable({}, {__tostring = function () return \22hello\22 end,\0A                            __name = \22hi\22})\0Aassert(string.format(\22%s %.10s\22, m, m) == \22hello hello\22)\0Agetmetatable(m).__tostring = nil   -- will use '__name' from now on\0Aassert(string.format(\22%.4s\22, m) == \22hi: \22)\0A\0Agetmetatable(m).__tostring = function () return {} end\0Acheckerror(\22'__tostring' must return a string\22, tostring, m)\0A\0A\0Aassert(string.format(\22%x\22, 0.0) == \220\22)\0Aassert(string.format(\22%02x\22, 0.0) == \2200\22)\0Aassert(string.format(\22%08X\22, 0xFFFFFFFF) == \22FFFFFFFF\22)\0Aassert(string.format(\22%+08d\22, 31501) == \22+0031501\22)\0Aassert(string.format(\22%+08d\22, -30927) == \22-0030927\22)\0A\0A\0Ado    -- longest number that can be formatted\0A  local i = 1\0A  local j = 10000\0A  while i + 1 < j do   -- binary search for maximum finite float\0A    local m = (i + j) // 2\0A    if 10^m < math.huge then i = m else j = m end\0A  end\0A  assert(10^i < math.huge and 10^j == math.huge)\0A  local s = string.format('%.99f', -(10^i))\0A  assert(string.len(s) >= i + 101)\0A  assert(tonumber(s) == -(10^i))\0A\0A  -- limit for floats\0A  assert(10^38 < math.huge)\0A  local s = string.format('%.99f', -(10^38))\0A  assert(string.len(s) >= 38 + 101)\0A  assert(tonumber(s) == -(10^38))\0Aend\0A\0A\0A-- testing large numbers for format\0Ado   -- assume at least 32 bits\0A  local max, min = 0x7fffffff, -0x80000000    -- \22large\22 for 32 bits\0A  assert(string.sub(string.format(\22%8x\22, -1), -8) == \22ffffffff\22)\0A  assert(string.format(\22%x\22, max) == \227fffffff\22)\0A  assert(string.sub(string.format(\22%x\22, min), -8) == \2280000000\22)\0A  assert(string.format(\22%d\22, max) ==  \222147483647\22)\0A  assert(string.format(\22%d\22, min) == \22-2147483648\22)\0A  assert(string.format(\22%u\22, 0xffffffff) == \224294967295\22)\0A  assert(string.format(\22%o\22, 0xABCD) == \22125715\22)\0A\0A  max, min = 0x7fffffffffffffff, -0x8000000000000000\0A  if max > 2.0^53 then  -- only for 64 bits\0A    assert(string.format(\22%x\22, (2^52 | 0) - 1) == \22fffffffffffff\22)\0A    assert(string.format(\220x%8X\22, 0x8f000003) == \220x8F000003\22)\0A    assert(string.format(\22%d\22, 2^53) == \229007199254740992\22)\0A    assert(string.format(\22%i\22, -2^53) == \22-9007199254740992\22)\0A    assert(string.format(\22%x\22, max) == \227fffffffffffffff\22)\0A    assert(string.format(\22%x\22, min) == \228000000000000000\22)\0A    assert(string.format(\22%d\22, max) ==  \229223372036854775807\22)\0A    assert(string.format(\22%d\22, min) == \22-9223372036854775808\22)\0A    assert(string.format(\22%u\22, ~(-1 << 64)) == \2218446744073709551615\22)\0A    assert(tostring(1234567890123) == '1234567890123')\0A  end\0Aend\0A\0A\0Ado print(\22testing 'format %a %A'\22)\0A  local function matchhexa (n)\0A    local s = string.format(\22%a\22, n)\0A    -- result matches ISO C requirements\0A    assert(string.find(s, \22^%-?0x[1-9a-f]%.?[0-9a-f]*p[-+]?%d+$\22))\0A    assert(tonumber(s) == n)  -- and has full precision\0A    s = string.format(\22%A\22, n)\0A    assert(string.find(s, \22^%-?0X[1-9A-F]%.?[0-9A-F]*P[-+]?%d+$\22))\0A    assert(tonumber(s) == n)\0A  end\0A  for _, n in ipairs{0.1, -0.1, 1/3, -1/3, 1e30, -1e30,\0A                     -45/247, 1, -1, 2, -2, 3e-20, -3e-20} do\0A    matchhexa(n)\0A  end\0A\0A  assert(string.find(string.format(\22%A\22, 0.0), \22^0X0%.?0*P%+?0$\22))\0A  assert(string.find(string.format(\22%a\22, -0.0), \22^%-0x0%.?0*p%+?0$\22))\0A\0A  if not _port then   -- test inf, -inf, NaN, and -0.0\0A    assert(string.find(string.format(\22%a\22, 1/0), \22^inf\22))\0A    assert(string.find(string.format(\22%A\22, -1/0), \22^%-INF\22))\0A    assert(string.find(string.format(\22%a\22, 0/0), \22^%-?nan\22))\0A    assert(string.find(string.format(\22%a\22, -0.0), \22^%-0x0\22))\0A  end\0A  \0A  if not pcall(string.format, \22%.3a\22, 0) then\0A    (Message or print)(\22\\n >>> modifiers for format '%a' not available <<<\\n\22)\0A  else\0A    assert(string.find(string.format(\22%+.2A\22, 12), \22^%+0X%x%.%x0P%+?%d$\22))\0A    assert(string.find(string.format(\22%.4A\22, -12), \22^%-0X%x%.%x000P%+?%d$\22))\0A  end\0Aend\0A\0A\0A-- testing some flags  (all these results are required by ISO C)\0Aassert(string.format(\22%#12o\22, 10) == \22         012\22)\0Aassert(string.format(\22%#10x\22, 100) == \22      0x64\22)\0Aassert(string.format(\22%#-17X\22, 100) == \220X64             \22)\0Aassert(string.format(\22%013i\22, -100) == \22-000000000100\22)\0Aassert(string.format(\22%2.5d\22, -100) == \22-00100\22)\0Aassert(string.format(\22%.u\22, 0) == \22\22)\0Aassert(string.format(\22%+#014.0f\22, 100) == \22+000000000100.\22)\0Aassert(string.format(\22%-16c\22, 97) == \22a               \22)\0Aassert(string.format(\22%+.3G\22, 1.5) == \22+1.5\22)\0Aassert(string.format(\22%.0s\22, \22alo\22)  == \22\22)\0Aassert(string.format(\22%.s\22, \22alo\22)  == \22\22)\0A\0A-- ISO C89 says that \22The exponent always contains at least two digits\22,\0A-- but unlike ISO C99 it does not ensure that it contains \22only as many\0A-- more digits as necessary\22.\0Aassert(string.match(string.format(\22% 1.0E\22, 100), \22^ 1E%+0+2$\22))\0Aassert(string.match(string.format(\22% .1g\22, 2^10), \22^ 1e%+0+3$\22))\0A\0A\0A-- errors in format\0A\0Alocal function check (fmt, msg)\0A  checkerror(msg, string.format, fmt, 10)\0Aend\0A\0Alocal aux = string.rep('0', 600)\0Acheck(\22%100.3d\22, \22invalid conversion\22)\0Acheck(\22%1\22..aux..\22.3d\22, \22too long\22)\0Acheck(\22%1.100d\22, \22invalid conversion\22)\0Acheck(\22%10.1\22..aux..\22004d\22, \22too long\22)\0Acheck(\22%t\22, \22invalid conversion\22)\0Acheck(\22%\22..aux..\22d\22, \22too long\22)\0Acheck(\22%d %d\22, \22no value\22)\0Acheck(\22%010c\22, \22invalid conversion\22)\0Acheck(\22%.10c\22, \22invalid conversion\22)\0Acheck(\22%0.34s\22, \22invalid conversion\22)\0Acheck(\22%#i\22, \22invalid conversion\22)\0Acheck(\22%3.1p\22, \22invalid conversion\22)\0Acheck(\22%0.s\22, \22invalid conversion\22)\0Acheck(\22%10q\22, \22cannot have modifiers\22)\0Acheck(\22%F\22, \22invalid conversion\22)   -- useless and not in C89\0A\0A\0Aassert(load(\22return 1\\n--comment without ending EOL\22)() == 1)\0A\0A\0Acheckerror(\22table expected\22, table.concat, 3)\0Acheckerror(\22at index \22 .. maxi, table.concat, {}, \22 \22, maxi, maxi)\0A-- '%' escapes following minus signal\0Acheckerror(\22at index %\22 .. mini, table.concat, {}, \22 \22, mini, mini)\0Aassert(table.concat{} == \22\22)\0Aassert(table.concat({}, 'x') == \22\22)\0Aassert(table.concat({'\\0', '\\0\\1', '\\0\\1\\2'}, '.\\0.') == \22\\0.\\0.\\0\\1.\\0.\\0\\1\\2\22)\0Alocal a = {}; for i=1,300 do a[i] = \22xuxu\22 end\0Aassert(table.concat(a, \22123\22)..\22123\22 == string.rep(\22xuxu123\22, 300))\0Aassert(table.concat(a, \22b\22, 20, 20) == \22xuxu\22)\0Aassert(table.concat(a, \22\22, 20, 21) == \22xuxuxuxu\22)\0Aassert(table.concat(a, \22x\22, 22, 21) == \22\22)\0Aassert(table.concat(a, \223\22, 299) == \22xuxu3xuxu\22)\0Aassert(table.concat({}, \22x\22, maxi, maxi - 1) == \22\22)\0Aassert(table.concat({}, \22x\22, mini + 1, mini) == \22\22)\0Aassert(table.concat({}, \22x\22, maxi, mini) == \22\22)\0Aassert(table.concat({[maxi] = \22alo\22}, \22x\22, maxi, maxi) == \22alo\22)\0Aassert(table.concat({[maxi] = \22alo\22, [maxi - 1] = \22y\22}, \22-\22, maxi - 1, maxi)\0A       == \22y-alo\22)\0A\0Aassert(not pcall(table.concat, {\22a\22, \22b\22, {}}))\0A\0Aa = {\22a\22,\22b\22,\22c\22}\0Aassert(table.concat(a, \22,\22, 1, 0) == \22\22)\0Aassert(table.concat(a, \22,\22, 1, 1) == \22a\22)\0Aassert(table.concat(a, \22,\22, 1, 2) == \22a,b\22)\0Aassert(table.concat(a, \22,\22, 2) == \22b,c\22)\0Aassert(table.concat(a, \22,\22, 3) == \22c\22)\0Aassert(table.concat(a, \22,\22, 4) == \22\22)\0A\0Aif not _port then\0A\0A  local locales = { \22ptb\22, \22pt_BR.iso88591\22, \22ISO-8859-1\22 }\0A  local function trylocale (w)\0A    for i = 1, #locales do\0A      if os.setlocale(locales[i], w) then\0A        print(string.format(\22'%s' locale set to '%s'\22, w, locales[i]))\0A        return locales[i]\0A      end\0A    end\0A    print(string.format(\22'%s' locale not found\22, w))\0A    return false\0A  end\0A\0A  if trylocale(\22collate\22)  then\0A    assert(\22alo\22 < \22\E1lo\22 and \22\E1lo\22 < \22amo\22)\0A  end\0A\0A  if trylocale(\22ctype\22) then\0A    assert(string.gsub(\22\E1\E9\ED\F3\FA\22, \22%a\22, \22x\22) == \22xxxxx\22)\0A    assert(string.gsub(\22\E1\C1\E9\C9\22, \22%l\22, \22x\22) == \22x\C1x\C9\22)\0A    assert(string.gsub(\22\E1\C1\E9\C9\22, \22%u\22, \22x\22) == \22\E1x\E9x\22)\0A    assert(string.upper\22\E1\C1\E9{xuxu}\E7\E3o\22 == \22\C1\C1\C9{XUXU}\C7\C3O\22)\0A  end\0A\0A  os.setlocale(\22C\22)\0A  assert(os.setlocale() == 'C')\0A  assert(os.setlocale(nil, \22numeric\22) == 'C')\0A\0Aend\0A\0A\0A-- bug in Lua 5.3.2\0A-- 'gmatch' iterator does not work across coroutines\0Ado\0A  local f = string.gmatch(\221 2 3 4 5\22, \22%d+\22)\0A  assert(f() == \221\22)\0A  local co = coroutine.wrap(f)\0A  assert(co() == \222\22)\0Aend\0A\0A\0Aif T==nil then\0A  (Message or print)\0A     (\22\\n >>> testC not active: skipping 'pushfstring' tests <<<\\n\22)\0Aelse\0A\0A  print\22testing 'pushfstring'\22\0A\0A  -- formats %U, %f, %I already tested elsewhere\0A\0A  local blen = 200    -- internal buffer length in 'luaO_pushfstring'\0A\0A  local function callpfs (op, fmt, n)\0A    local x = {T.testC(\22pushfstring\22 .. op .. \22; return *\22, fmt, n)}\0A    -- stack has code, 'fmt', 'n', and result from operation\0A    assert(#x == 4)  -- make sure nothing else was left in the stack\0A    return x[4]\0A  end\0A\0A  local function testpfs (op, fmt, n)\0A    assert(callpfs(op, fmt, n) == string.format(fmt, n))\0A  end\0A\0A  testpfs(\22I\22, \22\22, 0)\0A  testpfs(\22I\22, string.rep(\22a\22, blen - 1), 0)\0A  testpfs(\22I\22, string.rep(\22a\22, blen), 0)\0A  testpfs(\22I\22, string.rep(\22a\22, blen + 1), 0)\0A\0A  local str = string.rep(\22ab\22, blen) .. \22%d\22 .. string.rep(\22d\22, blen / 2)\0A  testpfs(\22I\22, str, 2^14)\0A  testpfs(\22I\22, str, -2^15)\0A\0A  str = \22%d\22 .. string.rep(\22cd\22, blen)\0A  testpfs(\22I\22, str, 2^14)\0A  testpfs(\22I\22, str, -2^15)\0A\0A  str = string.rep(\22c\22, blen - 2) .. \22%d\22\0A  testpfs(\22I\22, str, 2^14)\0A  testpfs(\22I\22, str, -2^15)\0A\0A  for l = 12, 14 do\0A    local str1 = string.rep(\22a\22, l)\0A    for i = 0, 500, 13 do\0A      for j = 0, 500, 13 do\0A        str = string.rep(\22a\22, i) .. \22%s\22 .. string.rep(\22d\22, j)\0A        testpfs(\22S\22, str, str1)\0A        testpfs(\22S\22, str, str)\0A      end\0A    end\0A  end\0A\0A  str = \22abc %c def\22\0A  testpfs(\22I\22, str, string.byte(\22A\22))\0A  testpfs(\22I\22, str, 255)\0A\0A  str = string.rep(\22a\22, blen - 1) .. \22%p\22 .. string.rep(\22cd\22, blen)\0A  testpfs(\22P\22, str, {})\0A\0A  str = string.rep(\22%%\22, 3 * blen) .. \22%p\22 .. string.rep(\22%%\22, 2 * blen)\0A  testpfs(\22P\22, str, {})\0Aend\0A\0A\0Aprint('OK')\0A\0A", align 16
@t19 = internal constant [18112 x i8] c"-- $Id: testes/gc.lua $\0A-- See Copyright Notice in file all.lua\0A\0Aprint('testing incremental garbage collection')\0A\0Alocal debug = require\22debug\22\0A\0Aassert(collectgarbage(\22isrunning\22))\0A\0Acollectgarbage()\0A\0Alocal oldmode = collectgarbage(\22incremental\22)\0A\0A-- changing modes should return previous mode\0Aassert(collectgarbage(\22generational\22) == \22incremental\22)\0Aassert(collectgarbage(\22generational\22) == \22generational\22)\0Aassert(collectgarbage(\22incremental\22) == \22generational\22)\0Aassert(collectgarbage(\22incremental\22) == \22incremental\22)\0A\0A\0Alocal function nop () end\0A\0Alocal function gcinfo ()\0A  return collectgarbage\22count\22 * 1024\0Aend\0A\0A\0A-- test weird parameters to 'collectgarbage'\0Ado\0A  -- save original parameters\0A  local a = collectgarbage(\22setpause\22, 200)\0A  local b = collectgarbage(\22setstepmul\22, 200)\0A  local t = {0, 2, 10, 90, 500, 5000, 30000, 0x7ffffffe}\0A  for i = 1, #t do\0A    local p = t[i]\0A    for j = 1, #t do\0A      local m = t[j]\0A      collectgarbage(\22setpause\22, p)\0A      collectgarbage(\22setstepmul\22, m)\0A      collectgarbage(\22step\22, 0)\0A      collectgarbage(\22step\22, 10000)\0A    end\0A  end\0A  -- restore original parameters\0A  collectgarbage(\22setpause\22, a)\0A  collectgarbage(\22setstepmul\22, b)\0A  collectgarbage()\0Aend\0A\0A\0A_G[\22while\22] = 234\0A\0A\0A--\0A-- tests for GC activation when creating different kinds of objects\0A--\0Alocal function GC1 ()\0A  local u\0A  local b     -- (above 'u' it in the stack)\0A  local finish = false\0A  u = setmetatable({}, {__gc = function () finish = true end})\0A  b = {34}\0A  repeat u = {} until finish\0A  assert(b[1] == 34)   -- 'u' was collected, but 'b' was not\0A\0A  finish = false; local i = 1\0A  u = setmetatable({}, {__gc = function () finish = true end})\0A  repeat i = i + 1; u = tostring(i) .. tostring(i) until finish\0A  assert(b[1] == 34)   --