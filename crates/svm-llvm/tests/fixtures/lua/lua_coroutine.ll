@t_coroutine = internal constant [6019 x i8] c"-- In-house coroutine differential for the on-ramp. Exercises the whole coroutine\0A-- library surface that does NOT need the debug library (that is a separate slice):\0A-- create/resume/yield, status transitions, running/isyieldable, wrap, error\0A-- propagation, yield across pcall/xpcall (the continuation machinery),\0A-- coroutine.close + <close> variables, and a producer/filter/consumer pipeline.\0A-- A failing assert raises, so a clean exit means every assert held \E2\80\94 identical to\0A-- native Lua.\0A\0Aprint \22testing coroutines (library slice)\22\0A\0A-- \E2\94\80\E2\94\80 basics: multi-value transfer in both directions \E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\0Ado\0A  local co = coroutine.create(function(a, b)\0A    assert(a == 1 and b == 2)\0A    local c = coroutine.yield(a + b, a * b)     -- yields 3, 2\0A    assert(c == 10)\0A    local d, e = coroutine.yield(c * 2)         -- yields 20\0A    assert(d == 5 and e == 6)\0A    return \22done\22, 42\0A  end)\0A  assert(coroutine.status(co) == \22suspended\22)\0A  local ok, s, p = coroutine.resume(co, 1, 2)\0A  assert(ok and s == 3 and p == 2)\0A  ok, s = coroutine.resume(co, 10)\0A  assert(ok and s == 20)\0A  ok, s, p = coroutine.resume(co, 5, 6)\0A  assert(ok and s == \22done\22 and p == 42)\0A  assert(coroutine.status(co) == \22dead\22)\0A  ok, s = coroutine.resume(co)\0A  assert(not ok and string.find(s, \22dead\22))     -- cannot resume dead coroutine\0Aend\0A\0A-- \E2\94\80\E2\94\80 coroutine.wrap \E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\0Ado\0A  local gen = coroutine.wrap(function()\0A    for i = 1, 3 do coroutine.yield(i * i) end\0A  end)\0A  assert(gen() == 1 and gen() == 4 and gen() == 9)\0A\0A  -- wrap propagates an error as a plain (re-raised) error, not (false, msg)\0A  local w = coroutine.wrap(function() error(\22wrapfail\22) end)\0A  local ok, err = pcall(w)\0A  assert(not ok and string.find(err, \22wrapfail\22))\0Aend\0A\0A-- \E2\94\80\E2\94\80 error out of create \E2\86\92 (false, msg); coroutine goes dead \E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\0Ado\0A  local eco = coroutine.create(function() error({code = 7}) end)   -- non-string error value\0A  local ok, err = coroutine.resume(eco)\0A  assert(not ok and type(err) == \22table\22 and err.code == 7)\0A  assert(coroutine.status(eco) == \22dead\22)\0Aend\0A\0A-- \E2\94\80\E2\94\80 running / isyieldable, main vs. inside a coroutine \E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\0Ado\0A  local main, ismain = coroutine.running()\0A  assert(type(main) == \22thread\22 and ismain == true)\0A  assert(coroutine.isyieldable() == false)\0A  assert(coroutine.isyieldable(main) == false)\0A\0A  local co\0A  co = coroutine.create(function()\0A    local self, im = coroutine.running()\0A    assert(self == co and im == false)\0A    assert(coroutine.isyieldable() == true)\0A    coroutine.yield()\0A  end)\0A  assert(coroutine.resume(co))\0Aend\0A\0A-- \E2\94\80\E2\94\80 status: \22normal\22 when a coroutine has resumed another \E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\0Ado\0A  local outer\0A  outer = coroutine.create(function()\0A    local inner = coroutine.create(function()\0A      assert(coroutine.status(outer) == \22normal\22)   -- outer is resuming us\0A      coroutine.yield()\0A    end)\0A    assert(coroutine.status(inner) == \22suspended\22)\0A    assert(coroutine.resume(inner))\0A    assert(coroutine.status(inner) == \22suspended\22)   -- inner yielded back\0A    return \22ok\22\0A  end)\0A  local ok, r = coroutine.resume(outer)\0A  assert(ok and r == \22ok\22)\0Aend\0A\0A-- \E2\94\80\E2\94\80 yield ACROSS a pcall boundary (yieldable pcall / continuations) \E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\0Ado\0A  local co = coroutine.wrap(function()\0A    local ok, r = pcall(function()\0A      local x = coroutine.yield(\22y1\22)\0A      assert(x == \22resumed\22)\0A      return \22pcall-ret\22\0A    end)\0A    assert(ok and r == \22pcall-ret\22)\0A    -- and across xpcall, with a message handler\0A    local ok2, r2 = xpcall(function()\0A      coroutine.yield(\22y2\22)\0A      error(\22boom\22)\0A    end, function(m) return \22handled:\22 .. m end)\0A    assert(not ok2 and string.find(r2, \22handled:\22) and string.find(r2, \22boom\22))\0A    coroutine.yield(\22y3\22)\0A  end)\0A  assert(co() == \22y1\22)\0A  assert(co(\22resumed\22) == \22y2\22)\0A  assert(co() == \22y3\22)\0Aend\0A\0A-- \E2\94\80\E2\94\80 coroutine.close: suspended \E2\86\92 dead, and <close> vars run on close \E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\0Ado\0A  local co = coroutine.create(function() coroutine.yield(1); coroutine.yield(2) end)\0A  assert(coroutine.resume(co))\0A  assert(coroutine.status(co) == \22suspended\22)\0A  local ok = coroutine.close(co)\0A  assert(ok == true and coroutine.status(co) == \22dead\22)\0A  assert(coroutine.close(co) == true)              -- closing a dead coroutine is ok\0A\0A  -- a to-be-closed variable inside a coroutine must run its __close when closed\0A  local closed = false\0A  local guard = setmetatable({}, {__close = function() closed = true end})\0A  local co2 = coroutine.create(function()\0A    local x <close> = guard\0A    coroutine.yield()\0A  end)\0A  assert(coroutine.resume(co2))\0A  assert(closed == false)                          -- still suspended, not yet closed\0A  assert(coroutine.close(co2) == true)\0A  assert(closed == true)                           -- __close fired on close\0Aend\0A\0A-- \E2\94\80\E2\94\80 a classic producer / filter / consumer pipeline \E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\0Ado\0A  local function producer()\0A    return coroutine.wrap(function()\0A      for i = 1, 5 do coroutine.yield(i) end\0A    end)\0A  end\0A  local function doubler(prod)\0A    return coroutine.wrap(function()\0A      for v in prod do coroutine.yield(v * 2) end\0A    end)\0A  end\0A  local sum = 0\0A  for v in doubler(producer()) do sum = sum + v end\0A  assert(sum == (1+2+3+4+5) * 2)\0Aend\0A\0A-- \E2\94\80\E2\94\80 two interleaved coroutines keep independent Lua stacks \E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\E2\94\80\0Ado\0A  local function counter(n)\0A    return coroutine.wrap(function() for i = 1, n do coroutine.yield(i) end end)\0A  end\0A  local a, b = counter(3), counter(3)\0A  assert(a() == 1 and b() == 1 and a() == 2 and a() == 3 and b() == 2 and b() == 3)\0Aend\0A\0Aprint \22ok\22\0A", align 16
